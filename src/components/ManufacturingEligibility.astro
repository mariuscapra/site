---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section data-industry-checker class="grain relative mt-8 overflow-hidden rounded-[2rem] bg-[#0f2233] text-white shadow-[0_30px_80px_rgba(15,34,51,0.24)]">
  <div class="pointer-events-none absolute -right-28 -top-32 h-96 w-96 rounded-full border-[68px] border-[#7eb99a]/10"></div>
  <div class="pointer-events-none absolute -bottom-48 -left-40 h-96 w-96 rounded-full bg-[#0f2233]/45"></div>

  <header class="relative border-b border-white/10 p-7 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-[#7eb99a] px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.15em] text-[#0f2233]">
          <span class="h-1.5 w-1.5 rounded-full bg-[#0f2233]"></span>
          Instrument orientativ
        </span>
        <h2 class="display-font mt-5 text-4xl leading-none sm:text-6xl">Calculator simplificat de punctaj</h2>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/76">
          Verifică trei condiții de bază și completează cele șapte criterii din grila programului. Vezi imediat punctajul estimat din maximum 340 de puncte.
        </p>
      </div>
      <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-xs leading-5 text-white/72">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 shrink-0 fill-none stroke-[#7eb99a]" stroke-width="1.8">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path>
          <path d="M9 12l2 2 4-5"></path>
        </svg>
        Bazat pe criteriile din Anexa nr. 5
      </div>
    </div>
  </header>

  <div class="relative grid xl:grid-cols-[1.08fr_0.92fr]">
    <div class="border-b border-white/10 p-7 sm:p-10 xl:border-b-0 xl:border-r">
      <section aria-labelledby="basic-check-title" class="rounded-[1.5rem] border border-white/12 bg-white/5 p-5 sm:p-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <span class="text-[10px] font-black uppercase tracking-[0.16em] text-[#7eb99a]">Pasul 1</span>
            <h3 id="basic-check-title" class="mt-1 text-xl font-extrabold">Pre-verificare de bază</h3>
          </div>
          <span class="text-[11px] text-white/70">3 verificări esențiale</span>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-xs font-bold text-white/72">Cod CAEN Rev. 3</span>
            <span class="mt-2 flex min-h-14 items-center rounded-2xl border border-white/12 bg-[#0f2233] px-4 focus-within:border-[#7eb99a]">
              <input
                data-industry-caen
                inputmode="numeric"
                maxlength="4"
                value="2511"
                class="min-w-0 flex-1 bg-transparent py-3 text-lg font-extrabold tracking-[0.12em] text-white outline-none"
                aria-describedby="industry-caen-feedback"
              />
              <span data-industry-caen-badge class="rounded-full bg-[#7eb99a] px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.1em] text-[#0f2233]">eligibil</span>
            </span>
            <span id="industry-caen-feedback" data-industry-caen-feedback class="mt-2 block text-[11px] leading-5 text-white/70">
              Codul apare în lista activităților eligibile.
            </span>
          </label>

          <label class="block">
            <span class="text-xs font-bold text-white/72">Costuri eligibile, fără TVA</span>
            <span class="mt-2 flex min-h-14 items-center rounded-2xl border border-white/12 bg-[#0f2233] px-4 focus-within:border-[#7eb99a]">
              <input
                data-industry-budget
                type="number"
                min="0"
                step="1000000"
                value="50000000"
                class="min-w-0 flex-1 bg-transparent py-3 text-lg font-extrabold text-white outline-none"
              />
              <span class="text-xs font-bold text-white/70">lei</span>
            </span>
            <span data-industry-budget-feedback class="mt-2 block text-[11px] leading-5 text-white/70">
              Prag minim: 50.000.000 lei.
            </span>
          </label>

          <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-[#0f2233] p-4 transition hover:border-[#7eb99a]/50 sm:col-span-2">
            <input data-industry-not-started class="mt-0.5 h-5 w-5 shrink-0 accent-[#7eb99a]" type="checkbox" checked />
            <span>
              <strong class="block text-sm">Investiția nu a fost demarată</strong>
              <span class="mt-1 block text-[11px] leading-5 text-white/70">Lucrările și comenzile ferme încep numai după depunerea cererii de finanțare.</span>
            </span>
          </label>
        </div>
      </section>

      <section aria-labelledby="score-grid-title" class="mt-8">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="text-[10px] font-black uppercase tracking-[0.16em] text-[#7eb99a]">Pasul 2</span>
            <h3 id="score-grid-title" class="mt-1 text-2xl font-extrabold">Grila de punctaj</h3>
          </div>
          <span class="text-xs font-bold text-[#7eb99a]">7 criterii · maximum 340 p.</span>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <label class="group rounded-2xl border border-white/12 bg-white/5 p-4 transition focus-within:border-[#7eb99a]/70">
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#7eb99a]/12 text-[10px] font-black text-[#7eb99a]">01</span>
              <span class="text-xs font-extrabold">Tipul investiției</span>
            </span>
            <select data-score-input="investment" class="mt-4 min-h-12 w-full rounded-xl border border-white/12 bg-[#0f2233] px-3 text-sm text-white outline-none">
              <option value="0">Selectează opțiunea</option>
              <option value="20">Unitate nouă / diversificare — 20 p.</option>
              <option value="10">Extinderea capacității existente — 10 p.</option>
            </select>
          </label>

          <label class="group rounded-2xl border border-white/12 bg-white/5 p-4 transition focus-within:border-[#7eb99a]/70">
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#7eb99a]/12 text-[10px] font-black text-[#7eb99a]">02</span>
              <span class="text-xs font-extrabold">Membru într-un cluster de inovare</span>
            </span>
            <select data-score-input="cluster" class="mt-4 min-h-12 w-full rounded-xl border border-white/12 bg-[#0f2233] px-3 text-sm text-white outline-none">
              <option value="0">Nu — 0 p.</option>
              <option value="20">Da — 20 p.</option>
            </select>
          </label>

          <label class="group rounded-2xl border border-white/12 bg-white/5 p-4 transition focus-within:border-[#7eb99a]/70 sm:col-span-2">
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#7eb99a]/12 text-[10px] font-black text-[#7eb99a]">03</span>
              <span class="text-xs font-extrabold">Locația realizării investiției</span>
            </span>
            <select data-industry-location class="mt-4 min-h-12 w-full rounded-xl border border-white/12 bg-[#0f2233] px-3 text-sm text-white outline-none">
              <option value="">Selectează județul sau zona</option>
              <optgroup label="Nord-Vest">
                <option value="bihor|40">Bihor — intensitate 40%</option>
                <option value="bistrita-nasaud|50">Bistrița-Năsăud — intensitate 50%</option>
                <option value="cluj|40">Cluj — intensitate 40%</option>
                <option value="maramures|50">Maramureș — intensitate 50%</option>
                <option value="satu-mare|50">Satu Mare — intensitate 50%</option>
                <option value="salaj|50">Sălaj — intensitate 50%</option>
              </optgroup>
              <optgroup label="Centru">
                <option value="alba|50">Alba — intensitate 50%</option>
                <option value="brasov|40">Brașov — intensitate 40%</option>
                <option value="covasna|40">Covasna — intensitate 40%</option>
                <option value="harghita|40">Harghita — intensitate 40%</option>
                <option value="mures|50">Mureș — intensitate 50%</option>
                <option value="sibiu|40">Sibiu — intensitate 40%</option>
              </optgroup>
              <optgroup label="Nord-Est">
                <option value="bacau|60">Bacău — intensitate 60%</option>
                <option value="botosani|60">Botoșani — intensitate 60%</option>
                <option value="iasi|50">Iași — intensitate 50%</option>
                <option value="neamt|60">Neamț — intensitate 60%</option>
                <option value="suceava|60">Suceava — intensitate 60%</option>
                <option value="vaslui|60">Vaslui — intensitate 60%</option>
              </optgroup>
              <optgroup label="Sud-Est">
                <option value="braila|60">Brăila — intensitate 60%</option>
                <option value="buzau|60">Buzău — intensitate 60%</option>
                <option value="constanta|50">Constanța — intensitate 50%</option>
                <option value="galati|70">Galați — intensitate 70%</option>
                <option value="vrancea|60">Vrancea — intensitate 60%</option>
                <option value="tulcea|60">Tulcea — intensitate 60%</option>
              </optgroup>
              <optgroup label="Sud-Muntenia">
                <option value="arges|50">Argeș — intensitate 50%</option>
                <option value="calarasi|60">Călărași — intensitate 60%</option>
                <option value="dambovita|50">Dâmbovița — intensitate 50%</option>
                <option value="giurgiu|50">Giurgiu — intensitate 50%</option>
                <option value="ialomita|60">Ialomița — intensitate 60%</option>
                <option value="prahova|70">Prahova — intensitate 70%</option>
                <option value="teleorman|60">Teleorman — intensitate 60%</option>
              </optgroup>
              <optgroup label="Sud-Vest Oltenia">
                <option value="dolj|70">Dolj — intensitate 70%</option>
                <option value="gorj|70">Gorj — intensitate 70%</option>
                <option value="mehedinti|60">Mehedinți — intensitate 60%</option>
                <option value="olt|60">Olt — intensitate 60%</option>
                <option value="valcea|60">Vâlcea — intensitate 60%</option>
              </optgroup>
              <optgroup label="Vest">
                <option value="arad|30">Arad — intensitate 30%</option>
                <option value="caras-severin|40">Caraș-Severin — intensitate 40%</option>
                <option value="hunedoara|50">Hunedoara — intensitate 50%</option>
                <option value="timis|30">Timiș — intensitate 30%</option>
              </optgroup>
              <optgroup label="București-Ilfov">
                <option value="ilfov-35|35">Ilfov — zona de intensitate 35%</option>
                <option value="ilfov-45|45">Ilfov — zona de intensitate 45%</option>
                <option value="bucuresti-ilfov-neacoperit|0">București / altă zonă Ilfov — intensitate sub 40%</option>
              </optgroup>
            </select>
            <span class="mt-2 block text-[10px] leading-5 text-white/70">Pentru Ilfov, verifică localitatea exactă în documentația oficială înainte de depunere.</span>
          </label>

          <label class="group rounded-2xl border border-white/12 bg-white/5 p-4 transition focus-within:border-[#7eb99a]/70">
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#7eb99a]/12 text-[10px] font-black text-[#7eb99a]">04</span>
              <span class="text-xs font-extrabold">Grupa produsului din Anexa nr. 2</span>
            </span>
            <select data-score-input="deficit" class="mt-4 min-h-12 w-full rounded-xl border border-white/12 bg-[#0f2233] px-3 text-sm text-white outline-none">
              <option value="0">Selectează grupa confirmată</option>
              <option value="100">Grupa 1 — 100 p.</option>
              <option value="80">Grupa 2 — 80 p.</option>
              <option value="60">Grupa 3 — 60 p.</option>
              <option value="40">Grupa 4 — 40 p.</option>
              <option value="20">Grupa 5 — 20 p.</option>
              <option value="0">Grupa 6 — 0 p.</option>
            </select>
            <span class="mt-2 block text-[10px] leading-5 text-[#7eb99a]">Selectează grupa numai după verificarea produsului CPA.</span>
          </label>

          <label class="group rounded-2xl border border-white/12 bg-white/5 p-4 transition focus-within:border-[#7eb99a]/70">
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#7eb99a]/12 text-[10px] font-black text-[#7eb99a]">05</span>
              <span class="text-xs font-extrabold">Gradul de automatizare</span>
            </span>
            <select data-score-input="automation" class="mt-4 min-h-12 w-full rounded-xl border border-white/12 bg-[#0f2233] px-3 text-sm text-white outline-none">
              <option value="0">Sub 10% — 0 p.</option>
              <option value="20">Minimum 10% — 20 p.</option>
              <option value="40">Minimum 20% — 40 p.</option>
              <option value="60">Minimum 30% — 60 p.</option>
              <option value="80">Minimum 40% — 80 p.</option>
            </select>
          </label>

          <label class="group rounded-2xl border border-white/12 bg-white/5 p-4 transition focus-within:border-[#7eb99a]/70">
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#7eb99a]/12 text-[10px] font-black text-[#7eb99a]">06</span>
              <span class="text-xs font-extrabold">Materii prime și materiale din SEE</span>
            </span>
            <select data-score-input="materials" class="mt-4 min-h-12 w-full rounded-xl border border-white/12 bg-[#0f2233] px-3 text-sm text-white outline-none">
              <option value="0">Sub 40% — 0 p.</option>
              <option value="30">Minimum 40% — 30 p.</option>
              <option value="50">Minimum 60% — 50 p.</option>
            </select>
          </label>

          <label class="group rounded-2xl border border-white/12 bg-white/5 p-4 transition focus-within:border-[#7eb99a]/70">
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#7eb99a]/12 text-[10px] font-black text-[#7eb99a]">07</span>
              <span class="text-xs font-extrabold">Reducerea intensității solicitate</span>
            </span>
            <select data-score-input="reduction" class="mt-4 min-h-12 w-full rounded-xl border border-white/12 bg-[#0f2233] px-3 text-sm text-white outline-none">
              <option value="0">Fără reducere — 0 p.</option>
              <option value="5">Cu minimum 5% — 5 p.</option>
              <option value="10">Cu minimum 10% — 10 p.</option>
              <option value="15">Cu minimum 15% — 15 p.</option>
              <option value="20">Cu minimum 20% — 20 p.</option>
            </select>
          </label>
        </div>
      </section>
    </div>

    <aside class="bg-[#0f2233]/82 p-7 sm:p-10">
      <div class="sticky top-28">
        <span class="text-[10px] font-extrabold uppercase tracking-[0.16em] text-[#7eb99a]">Rezultatul tău orientativ</span>

        <div class="mt-4 rounded-[1.5rem] border border-white/10 bg-white/6 p-5 sm:p-6">
          <div class="flex items-end justify-between gap-4">
            <div>
              <span class="text-xs font-bold text-white/70">Punctaj estimat</span>
              <strong data-industry-score class="mt-1 block text-4xl font-black text-white" aria-live="polite">0 <span class="text-lg text-white/70">/ 340</span></strong>
            </div>
            <span data-industry-percentage class="text-2xl font-black text-[#7eb99a]">0%</span>
          </div>
          <div class="mt-5 h-2.5 overflow-hidden rounded-full bg-white/10">
            <div data-industry-progress-bar class="h-full w-0 rounded-full bg-[#7eb99a] transition-[width] duration-300"></div>
          </div>
        </div>

        <div class="mt-4 rounded-2xl border border-[#7eb99a]/20 bg-[#7eb99a]/8 p-5">
          <strong data-industry-status class="block text-base text-[#f5f7f6]" aria-live="polite">Pre-verificare de bază îndeplinită</strong>
          <p data-industry-message class="mt-2 text-xs leading-6 text-white/72">
            Codul CAEN, valoarea investiției și momentul începerii trec verificările automate de bază.
          </p>
        </div>

        <div class="mt-6 flex items-center justify-between rounded-2xl border border-white/10 px-4 py-3">
          <span class="text-xs font-bold text-white/72">Intensitate regională selectată</span>
          <strong data-industry-intensity class="text-lg text-[#7eb99a]">—</strong>
        </div>

        <div class="mt-7">
          <div class="flex items-center justify-between">
            <span class="text-[10px] font-black uppercase tracking-[0.14em] text-[#7eb99a]">Cum se formează scorul</span>
            <span class="text-[10px] text-white/70">Anexa nr. 5</span>
          </div>
          <ul class="mt-4 grid gap-2 text-xs">
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2"><span class="text-white/72">Investiția inițială</span><strong data-score-row="investment">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2"><span class="text-white/72">Cluster de inovare</span><strong data-score-row="cluster">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2"><span class="text-white/72">Locația investiției</span><strong data-score-row="location">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2"><span class="text-white/72">Grupa produsului</span><strong data-score-row="deficit">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2"><span class="text-white/72">Gradul de automatizare</span><strong data-score-row="automation">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2"><span class="text-white/72">Materiale din SEE</span><strong data-score-row="materials">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 py-2"><span class="text-white/72">Reducerea intensității</span><strong data-score-row="reduction">0 p.</strong></li>
          </ul>
        </div>

        <div class="mt-7 rounded-2xl border border-[#7eb99a]/20 bg-[#7eb99a]/7 p-4 text-[11px] leading-5 text-white/72">
          Grila nu stabilește un punctaj care garantează finanțarea. Cererile sunt ordonate descrescător și analizate în limita bugetului sesiunii.
        </div>

        <a href={`${base}/#contact`} class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#7eb99a] px-6 py-4 text-sm font-extrabold text-[#0f2233] transition hover:-translate-y-0.5 hover:bg-[#7eb99a]">
          Cere verificarea completă
          <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5"></path></svg>
        </a>
        <p class="mt-4 text-center text-[10px] leading-5 text-white/70">
          Rezultatul este orientativ. Documentația finală și evaluarea autorității competente prevalează.
        </p>
      </div>
    </aside>
  </div>
</section>

<script is:inline>
  (() => {
    const checker = document.querySelector('[data-industry-checker]');
    if (!checker) return;

    const eligibleCaen = new Set('1011,1012,1013,1020,1031,1032,1039,1041,1042,1051,1052,1061,1062,1071,1072,1073,1081,1082,1083,1084,1085,1086,1089,1091,1092,1101,1102,1103,1104,1105,1106,1107,1200,1310,1320,1330,1391,1392,1393,1394,1395,1396,1399,1410,1421,1422,1423,1424,1429,1511,1512,1520,1611,1612,1621,1622,1623,1624,1625,1626,1627,1628,1711,1712,1721,1722,1723,1724,1725,1811,1812,1813,1814,1820,1910,1920,2011,2012,2013,2014,2015,2016,2017,2020,2030,2041,2042,2051,2059,2060,2110,2120,2211,2212,2221,2222,2223,2224,2225,2226,2311,2312,2313,2314,2315,2320,2331,2332,2341,2342,2343,2344,2345,2351,2352,2361,2362,2363,2364,2365,2366,2370,2391,2399,2441,2442,2443,2444,2445,2446,2453,2454,2511,2512,2521,2522,2530,2540,2551,2552,2553,2561,2562,2563,2591,2592,2593,2594,2599,2611,2612,2620,2630,2640,2651,2652,2660,2670,2711,2712,2720,2731,2732,2733,2740,2751,2752,2790,2811,2812,2813,2814,2815,2821,2822,2823,2824,2825,2829,2830,2841,2842,2891,2892,2893,2894,2895,2896,2897,2899,2910,2920,2931,2932,3011,3012,3013,3020,3031,3032,3040,3091,3092,3099,3100,3211,3212,3213,3220,3230,3240,3250,3291,3299,3311,3312,3313,3314,3315,3316,3317,3318,3319,3320'.split(','));
    const caenInput = checker.querySelector('[data-industry-caen]');
    const budgetInput = checker.querySelector('[data-industry-budget]');
    const notStartedInput = checker.querySelector('[data-industry-not-started]');
    const locationInput = checker.querySelector('[data-industry-location]');
    const scoreInputs = [...checker.querySelectorAll('[data-score-input]')];

    const setText = (selector, value) => {
      const element = checker.querySelector(selector);
      if (element) element.textContent = value;
    };

    const getPoints = (name) => Number(checker.querySelector(`[data-score-input="${name}"]`)?.value) || 0;

    const update = () => {
      const caen = String(caenInput?.value ?? '').replace(/\D/g, '').slice(0, 4);
      if (caenInput && caenInput.value !== caen) caenInput.value = caen;
      const caenOk = caen.length === 4 && eligibleCaen.has(caen);

      const budget = Math.max(0, Number(budgetInput?.value) || 0);
      const budgetOk = budget >= 50000000;
      const notStarted = Boolean(notStartedInput?.checked);

      const [, intensityValue = '0'] = String(locationInput?.value ?? '').split('|');
      const intensity = Math.max(0, Number(intensityValue) || 0);
      const locationPoints = intensity === 70
        ? 50
        : intensity === 60
          ? 40
          : intensity === 50
            ? 30
            : (intensity === 40 || intensity === 45)
              ? 5
              : 0;

      const scores = {
        investment: getPoints('investment'),
        cluster: getPoints('cluster'),
        location: locationPoints,
        deficit: getPoints('deficit'),
        automation: getPoints('automation'),
        materials: getPoints('materials'),
        reduction: getPoints('reduction'),
      };
      const total = Object.values(scores).reduce((sum, value) => sum + value, 0);
      const percentage = Math.round((total / 340) * 100);

      setText('[data-industry-score]', `${total} / 340`);
      setText('[data-industry-percentage]', `${percentage}%`);
      setText('[data-industry-intensity]', locationInput?.value ? `${intensity}%` : '—');
      Object.entries(scores).forEach(([name, value]) => setText(`[data-score-row="${name}"]`, `${value} p.`));

      const progressBar = checker.querySelector('[data-industry-progress-bar]');
      if (progressBar) progressBar.style.width = `${percentage}%`;

      const caenBadge = checker.querySelector('[data-industry-caen-badge]');
      if (caenBadge) {
        caenBadge.textContent = caenOk ? 'eligibil' : 'neeligibil';
        caenBadge.classList.toggle('bg-[#7eb99a]', caenOk);
        caenBadge.classList.toggle('text-[#0f2233]', caenOk);
        caenBadge.classList.toggle('bg-[#7eb99a]', !caenOk);
        caenBadge.classList.toggle('text-[#0f2233]', !caenOk);
      }
      setText(
        '[data-industry-caen-feedback]',
        caenOk
          ? 'Codul apare în lista activităților eligibile.'
          : caen.length < 4
            ? 'Introdu un cod CAEN Rev. 3 format din 4 cifre.'
            : 'Codul nu apare în lista activităților eligibile din Anexa nr. 1.',
      );
      setText(
        '[data-industry-budget-feedback]',
        budgetOk
          ? 'Valoarea trece pragul minim de 50.000.000 lei.'
          : 'Valoarea este sub pragul minim de 50.000.000 lei.',
      );

      let status = 'Pre-verificare de bază îndeplinită';
      let message = 'Codul CAEN, valoarea investiției și momentul începerii trec verificările automate de bază.';
      if (!notStarted) {
        status = 'Atenție: investiția pare demarată';
        message = 'Începerea lucrărilor sau existența unei comenzi ferme înainte de depunere poate face investiția neeligibilă.';
      } else if (!caenOk) {
        status = 'Cod CAEN neeligibil sau incomplet';
        message = 'Verifică și introdu un cod CAEN Rev. 3 din lista activităților eligibile.';
      } else if (!budgetOk) {
        status = 'Investiție sub pragul minim';
        message = 'Costurile eligibile trebuie să fie de minimum 50.000.000 lei, fără TVA.';
      }
      setText('[data-industry-status]', status);
      setText('[data-industry-message]', message);
    };

    [caenInput, budgetInput, notStartedInput, locationInput, ...scoreInputs]
      .filter(Boolean)
      .forEach((input) => input.addEventListener('input', update));

    update();
  })();
</script>
