---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section data-industry-checker class="grain relative mt-8 overflow-hidden rounded-[2rem] bg-[#073d2c] text-white shadow-[0_30px_80px_rgba(7,61,44,0.24)]">
  <div class="absolute -right-32 -top-32 h-96 w-96 rounded-full border-[70px] border-[#a7d46f]/10"></div>
  <div class="absolute -bottom-48 -left-40 h-96 w-96 rounded-full bg-[#0b6b49]/45"></div>

  <div class="relative border-b border-white/10 p-7 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-[#a7d46f] px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.15em] text-[#073d2c]">
          <span class="h-1.5 w-1.5 rounded-full bg-[#073d2c]"></span>
          Instrument interactiv
        </span>
        <h2 class="display-font mt-5 text-5xl leading-none sm:text-6xl">Pre-eligibilitate industrială</h2>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/68">Verifică rapid criteriile eliminatorii, codul CAEN Rev. 3 și intensitatea regională. Apoi construiește un punctaj orientativ pentru investiția ta.</p>
      </div>
      <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-xs leading-5 text-white/58">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 shrink-0 fill-none stroke-[#a7d46f]" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" /><path d="M12 8v4m0 4h.01" /></svg>
        Rezultat orientativ, bazat pe proiectul schemei
      </div>
    </div>
  </div>

  <div class="relative grid xl:grid-cols-[1.12fr_0.88fr]">
    <div class="border-b border-white/10 p-7 sm:p-10 xl:border-b-0 xl:border-r">
      <fieldset>
        <legend class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#cfe8a8]">1. Profilul întreprinderii</legend>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="industry-company" value="active" checked />
            <span class="flex min-h-24 flex-col rounded-2xl border border-white/12 bg-white/5 p-4 transition peer-checked:border-[#a7d46f] peer-checked:bg-[#a7d46f]/12">
              <strong class="text-sm">Întreprindere în activitate</strong>
              <span class="mt-1 text-xs leading-5 text-white/48">Cu exerciții financiare încheiate</span>
            </span>
          </label>
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="industry-company" value="new" />
            <span class="flex min-h-24 flex-col rounded-2xl border border-white/12 bg-white/5 p-4 transition peer-checked:border-[#a7d46f] peer-checked:bg-[#a7d46f]/12">
              <strong class="text-sm">Întreprindere nou-înființată</strong>
              <span class="mt-1 text-xs leading-5 text-white/48">Capital social vărsat de minimum 100.000 lei</span>
            </span>
          </label>
        </div>
      </fieldset>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <label class="block">
          <span class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#cfe8a8]">2. Cod CAEN Rev. 3</span>
          <span class="mt-3 flex items-center rounded-2xl border border-white/12 bg-white/7 px-4 focus-within:border-[#a7d46f]">
            <input data-industry-caen inputmode="numeric" maxlength="4" value="2511" class="min-w-0 flex-1 bg-transparent py-4 text-lg font-extrabold tracking-[0.12em] text-white outline-none" aria-describedby="industry-caen-feedback" />
            <span data-industry-caen-badge class="rounded-full bg-[#a7d46f] px-2.5 py-1 text-[9px] font-black uppercase tracking-[0.1em] text-[#073d2c]">eligibil</span>
          </span>
          <span id="industry-caen-feedback" data-industry-caen-feedback class="mt-2 block text-[11px] leading-5 text-white/45">Codul apare în lista celor 224 de activități eligibile.</span>
        </label>

        <label class="block">
          <span class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#cfe8a8]">3. Costuri eligibile</span>
          <span class="mt-3 flex items-center rounded-2xl border border-white/12 bg-white/7 px-4 focus-within:border-[#a7d46f]">
            <input data-industry-budget type="number" min="0" step="1000000" value="50000000" class="min-w-0 flex-1 bg-transparent py-4 text-lg font-extrabold text-white outline-none" />
            <span class="text-xs font-bold text-white/45">lei</span>
          </span>
          <input data-industry-budget-range aria-label="Costuri eligibile estimate" type="range" min="10000000" max="500000000" step="5000000" value="50000000" class="mt-3 w-full accent-[#a7d46f]" />
          <span class="mt-2 block text-[11px] text-white/42">Prag eliminatoriu: minimum 50 milioane lei, fără TVA</span>
        </label>

        <label class="block">
          <span class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#cfe8a8]">4. Locația investiției</span>
          <select data-industry-location class="mt-3 min-h-14 w-full rounded-2xl border border-white/12 bg-[#0a4735] px-4 text-sm font-bold text-white outline-none transition focus:border-[#a7d46f]">
            <option value="70">Galați, Prahova, Dolj sau Gorj — 70%</option>
            <option value="60">Județ cu intensitate de 60%</option>
            <option value="50">Județ cu intensitate de 50%</option>
            <option value="40">Județ cu intensitate de 40%</option>
            <option value="30">Arad sau Timiș — 30%</option>
            <option value="45">Ilfov — localități cu intensitate de 45%</option>
            <option value="35">Ilfov — localități cu intensitate de 35%</option>
            <option value="0">București / locație care necesită verificare</option>
          </select>
          <details class="mt-2 text-[11px] leading-5 text-white/45">
            <summary class="cursor-pointer font-bold text-[#cfe8a8]">Vezi încadrarea județelor</summary>
            <p class="mt-2">60%: Bacău, Botoșani, Neamț, Suceava, Vaslui, Brăila, Buzău, Vrancea, Călărași, Ialomița, Teleorman, Mehedinți, Olt și Vâlcea.</p>
            <p class="mt-1">50%: Bistrița-Năsăud, Maramureș, Satu Mare, Sălaj, Alba, Mureș, Iași, Constanța, Argeș, Dâmbovița, Giurgiu și Hunedoara.</p>
            <p class="mt-1">40%: Bihor, Cluj, Brașov, Covasna, Harghita, Sibiu și Caraș-Severin.</p>
          </details>
        </label>

        <label class="block">
          <span class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#cfe8a8]">5. Obiectiv de mediu</span>
          <select data-industry-environment class="mt-3 min-h-14 w-full rounded-2xl border border-white/12 bg-[#0a4735] px-4 text-sm font-bold text-white outline-none transition focus:border-[#a7d46f]">
            <option value="">Nu este încă demonstrat</option>
            <option value="energy">Consum de energie redus cu min. 20%</option>
            <option value="carbon">Emisii CO₂ reduse cu min. 15%</option>
            <option value="circular">Materii prime/deșeuri reduse cu min. 10%</option>
            <option value="pollution">Prevenirea poluării peste cerințele obligatorii</option>
          </select>
        </label>
      </div>

      <fieldset class="mt-8">
        <legend class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#cfe8a8]">6. Condiții eliminatorii</legend>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#a7d46f]/45">
            <input data-industry-check="financial" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
            <span><strong data-industry-financial-title class="block text-xs">Rentabilitate și capitaluri pozitive</strong><span data-industry-financial-note class="mt-1 block text-[11px] leading-4 text-white/45">Rentabilitate &gt; 0 într-unul din ultimii 3 ani</span></span>
          </label>
          <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#a7d46f]/45">
            <input data-industry-check="legal" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
            <span><strong class="block text-xs">Situație juridică eligibilă</strong><span class="mt-1 block text-[11px] leading-4 text-white/45">Fără dificultate, insolvență sau executare</span></span>
          </label>
          <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#a7d46f]/45">
            <input data-industry-check="recovery" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
            <span><strong class="block text-xs">Fără ajutor nerecuperat</strong><span class="mt-1 block text-[11px] leading-4 text-white/45">Deciziile de recuperare sunt stinse</span></span>
          </label>
          <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#a7d46f]/45">
            <input data-industry-check="private" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
            <span><strong class="block text-xs">Contribuție privată disponibilă</strong><span class="mt-1 block text-[11px] leading-4 text-white/45">Minimum 25%, fără alt ajutor public</span></span>
          </label>
          <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#e8a96a]/55 sm:col-span-2">
            <input data-industry-check="not-started" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
            <span><strong class="block text-xs">Investiția nu a fost demarată</strong><span class="mt-1 block text-[11px] leading-4 text-white/45">Lucrările și comenzile ferme încep numai după depunerea cererii</span></span>
          </label>
        </div>
      </fieldset>

      <details open class="mt-8 rounded-[1.5rem] border border-[#a7d46f]/18 bg-[#062f22]/72">
        <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 text-xs font-extrabold uppercase tracking-[0.15em] text-[#cfe8a8]">
          Estimează punctajul competitiv
          <span class="grid h-7 w-7 place-items-center rounded-full bg-white/8 text-lg">+</span>
        </summary>
        <div class="grid gap-5 border-t border-white/8 p-5 sm:grid-cols-2">
          <label class="text-xs font-bold text-white/70">Tipul investiției
            <select data-industry-points="investment" class="mt-2 min-h-12 w-full rounded-xl border border-white/12 bg-[#0a4735] px-3 text-white outline-none">
              <option value="20">Unitate nouă / diversificarea unei unități noi — 20 p.</option>
              <option value="10">Extinderea capacității unei unități existente — 10 p.</option>
              <option value="0">Alt tip — necesită verificare</option>
            </select>
          </label>
          <label class="text-xs font-bold text-white/70">Grupa produsului cu deficit
            <select data-industry-points="deficit" class="mt-2 min-h-12 w-full rounded-xl border border-white/12 bg-[#0a4735] px-3 text-white outline-none">
              <option value="100">Grupa 1 — 100 p.</option><option value="80">Grupa 2 — 80 p.</option>
              <option value="60">Grupa 3 — 60 p.</option><option value="40">Grupa 4 — 40 p.</option>
              <option value="20">Grupa 5 — 20 p.</option><option value="0">Grupa 6 / produs fără date — 0 p.</option>
            </select>
          </label>
          <label class="text-xs font-bold text-white/70">Gradul de automatizare
            <select data-industry-points="automation" class="mt-2 min-h-12 w-full rounded-xl border border-white/12 bg-[#0a4735] px-3 text-white outline-none">
              <option value="80">Minimum 40% — 80 p.</option><option value="60">Minimum 30% — 60 p.</option>
              <option value="40">Minimum 20% — 40 p.</option><option value="20">Minimum 10% — 20 p.</option>
              <option value="0">Sub 10% — 0 p.</option>
            </select>
          </label>
          <label class="text-xs font-bold text-white/70">Materii prime și materiale din SEE
            <select data-industry-points="materials" class="mt-2 min-h-12 w-full rounded-xl border border-white/12 bg-[#0a4735] px-3 text-white outline-none">
              <option value="50">Minimum 60% — 50 p.</option><option value="30">Minimum 40% — 30 p.</option>
              <option value="0">Sub 40% — 0 p.</option>
            </select>
          </label>
          <label class="text-xs font-bold text-white/70">Reducerea intensității solicitate
            <select data-industry-reduction class="mt-2 min-h-12 w-full rounded-xl border border-white/12 bg-[#0a4735] px-3 text-white outline-none">
              <option value="0">Fără reducere — 0 p.</option><option value="5">Cu minimum 5% — 5 p.</option>
              <option value="10">Cu minimum 10% — 10 p.</option><option value="15">Cu minimum 15% — 15 p.</option>
              <option value="20">Cu minimum 20% — 20 p.</option>
            </select>
          </label>
          <label class="flex cursor-pointer items-center gap-3 self-end rounded-xl border border-white/12 bg-white/5 p-3.5 text-xs font-bold text-white/70">
            <input data-industry-cluster class="h-5 w-5 accent-[#a7d46f]" type="checkbox" />
            Întreprinderea face parte dintr-un cluster de inovare — 20 p.
          </label>
        </div>
      </details>
    </div>

    <aside class="bg-[#062f22]/82 p-7 sm:p-10">
      <div class="sticky top-28">
        <div class="flex items-center justify-between gap-5">
          <div>
            <span class="text-[10px] font-extrabold uppercase tracking-[0.16em] text-[#a7d46f]">Rezultat preliminar</span>
            <strong data-industry-status class="mt-2 block text-2xl text-white" aria-live="polite">Potențial eligibil</strong>
          </div>
          <div data-industry-progress class="grid h-20 w-20 shrink-0 place-items-center rounded-full p-[7px]" style="background: conic-gradient(#a7d46f 100%, rgba(255,255,255,.12) 0)">
            <div class="grid h-full w-full place-items-center rounded-full bg-[#062f22] text-sm font-black text-white"><span data-industry-readiness>100%</span></div>
          </div>
        </div>

        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
            <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">CAEN verificat</span>
            <strong data-industry-caen-result class="mt-2 block text-xl text-[#a7d46f]">2511 · eligibil</strong>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
            <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">Intensitate solicitată</span>
            <strong data-industry-intensity class="mt-2 block text-xl text-[#a7d46f]">70%</strong>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
            <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">Ajutor estimat</span>
            <strong data-industry-aid class="mt-2 block text-xl text-[#a7d46f]">35 mil. lei</strong>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
            <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">Punctaj orientativ</span>
            <strong data-industry-score class="mt-2 block text-xl text-white">300 / 340</strong>
          </div>
        </div>

        <div class="mt-7 rounded-2xl border border-[#a7d46f]/20 bg-[#a7d46f]/8 p-5">
          <p data-industry-message class="text-sm font-semibold leading-6 text-[#eaf5db]">Profilul introdus îndeplinește reperele principale. Următorul pas este verificarea produsului CPA, a documentelor și a viabilității financiare.</p>
        </div>

        <div class="mt-7 rounded-2xl border border-white/10 p-5">
          <span class="text-[10px] font-black uppercase tracking-[0.14em] text-[#cfe8a8]">Ce trebuie verificat înainte de depunere</span>
          <ul class="mt-4 grid gap-3 text-xs leading-5 text-white/58">
            <li class="flex gap-3"><span class="text-[#a7d46f]">01</span><span>Produsul CPA și grupa exactă de deficit comercial.</span></li>
            <li class="flex gap-3"><span class="text-[#a7d46f]">02</span><span>Indicatorii de solvabilitate, lichiditate, rentabilitate și îndatorare.</span></li>
            <li class="flex gap-3"><span class="text-[#a7d46f]">03</span><span>Documentele locației, sursa cofinanțării și dovada pieței pentru noile produse.</span></li>
          </ul>
        </div>

        <a href={`${base}/#contact`} class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#a7d46f] px-6 py-4 text-sm font-extrabold text-[#073d2c] transition hover:-translate-y-0.5 hover:bg-[#cfe8a8]">
          Cere verificarea completă
          <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
        </a>
        <p class="mt-4 text-center text-[10px] leading-5 text-white/35">Instrumentul nu reprezintă o decizie de eligibilitate. Ghidul final și evaluarea Ministerului Finanțelor prevalează.</p>
      </div>
    </aside>
  </div>
</section>

<script is:inline>
  (() => {
    const checker = document.querySelector('[data-industry-checker]');
    if (!checker) return;

    const eligibleCaen = new Set('1011,1012,1013,1020,1031,1032,1039,1041,1042,1051,1052,1061,1062,1071,1072,1073,1081,1082,1083,1084,1085,1086,1089,1091,1092,1101,1102,1103,1104,1105,1106,1107,1200,1310,1320,1330,1391,1392,1393,1394,1395,1396,1399,1410,1421,1422,1423,1424,1429,1511,1512,1520,1611,1612,1621,1622,1623,1624,1625,1626,1627,1628,1711,1712,1721,1722,1723,1724,1725,1811,1812,1813,1814,1820,1910,1920,2011,2012,2013,2014,2015,2016,2017,2020,2030,2041,2042,2051,2059,2060,2110,2120,2211,2212,2221,2222,2223,2224,2225,2226,2311,2312,2313,2314,2315,2320,2331,2332,2341,2342,2343,2344,2345,2351,2352,2361,2362,2363,2364,2365,2366,2370,2391,2399,2441,2442,2443,2444,2445,2446,2453,2454,2511,2512,2521,2522,2530,2540,2551,2552,2553,2561,2562,2563,2591,2592,2593,2594,2599,2611,2612,2620,2630,2640,2651,2652,2660,2670,2711,2712,2720,2731,2732,2733,2740,2751,2752,2790,2811,2812,2813,2814,2815,2821,2822,2823,2824,2825,2829,2830,2841,2842,2891,2892,2893,2894,2895,2896,2897,2899,2910,2920,2931,2932,3011,3012,3013,3020,3031,3032,3040,3091,3092,3099,3100,3211,3212,3213,3220,3230,3240,3250,3291,3299,3311,3312,3313,3314,3315,3316,3317,3318,3319,3320'.split(','));
    const companyInputs = [...checker.querySelectorAll('input[name="industry-company"]')];
    const caenInput = checker.querySelector('[data-industry-caen]');
    const budgetInput = checker.querySelector('[data-industry-budget]');
    const budgetRange = checker.querySelector('[data-industry-budget-range]');
    const locationInput = checker.querySelector('[data-industry-location]');
    const environmentInput = checker.querySelector('[data-industry-environment]');
    const reductionInput = checker.querySelector('[data-industry-reduction]');
    const clusterInput = checker.querySelector('[data-industry-cluster]');
    const pointInputs = [...checker.querySelectorAll('[data-industry-points]')];
    const conditionInputs = [...checker.querySelectorAll('[data-industry-check]')];
    const formatNumber = new Intl.NumberFormat('ro-RO', { maximumFractionDigits: 1 });

    const text = (selector, value) => {
      const element = checker.querySelector(selector);
      if (element) element.textContent = value;
    };
    const checked = (name) => checker.querySelector(`[data-industry-check="${name}"]`)?.checked ?? false;
    const points = (name) => Number(checker.querySelector(`[data-industry-points="${name}"]`)?.value) || 0;
    const compactLei = (value) => value >= 1000000 ? `${formatNumber.format(value / 1000000)} mil. lei` : `${formatNumber.format(value)} lei`;

    const update = () => {
      const company = companyInputs.find((input) => input.checked)?.value ?? 'active';
      const caen = String(caenInput?.value ?? '').replace(/\D/g, '').slice(0, 4);
      if (caenInput && caenInput.value !== caen) caenInput.value = caen;
      const caenOk = caen.length === 4 && eligibleCaen.has(caen);
      const budget = Math.max(0, Number(budgetInput?.value) || 0);
      const budgetOk = budget >= 50000000;
      const regionalIntensity = Math.max(0, Number(locationInput?.value) || 0);
      const locationOk = regionalIntensity > 0;
      const environmentOk = Boolean(environmentInput?.value);
      const notStarted = checked('not-started');
      const hardConditions = [
        caenOk,
        budgetOk,
        locationOk,
        environmentOk,
        checked('financial'),
        checked('legal'),
        checked('recovery'),
        checked('private'),
        notStarted,
      ];
      const readiness = Math.round((hardConditions.filter(Boolean).length / hardConditions.length) * 100);

      const reduction = Math.max(0, Number(reductionInput?.value) || 0);
      const requestedIntensity = Math.max(0, regionalIntensity - reduction);
      const locationPoints = regionalIntensity === 70 ? 50 : regionalIntensity === 60 ? 40 : regionalIntensity === 50 ? 30 : (regionalIntensity === 40 || regionalIntensity === 45) ? 5 : 0;
      const score = points('investment') + points('deficit') + points('automation') + points('materials') + reduction + locationPoints + (clusterInput?.checked ? 20 : 0);

      const eligibleEuro = budget / 5.06;
      const adjustedBaseEuro = Math.min(eligibleEuro, 55000000) + Math.min(Math.max(eligibleEuro - 55000000, 0), 55000000) * 0.5;
      const estimatedAidLei = adjustedBaseEuro * (requestedIntensity / 100) * 5.06;

      text('[data-industry-readiness]', `${readiness}%`);
      text('[data-industry-caen-result]', caen ? `${caen} · ${caenOk ? 'eligibil' : 'neeligibil'}` : 'Introdu codul');
      text('[data-industry-intensity]', locationOk ? `${requestedIntensity}%` : '—');
      text('[data-industry-aid]', budgetOk && locationOk ? compactLei(estimatedAidLei) : '—');
      text('[data-industry-score]', `${score} / 340`);

      const caenBadge = checker.querySelector('[data-industry-caen-badge]');
      const caenFeedback = checker.querySelector('[data-industry-caen-feedback]');
      if (caenBadge) {
        caenBadge.textContent = caenOk ? 'eligibil' : 'neeligibil';
        caenBadge.classList.toggle('bg-[#a7d46f]', caenOk);
        caenBadge.classList.toggle('text-[#073d2c]', caenOk);
        caenBadge.classList.toggle('bg-[#e8a96a]', !caenOk);
        caenBadge.classList.toggle('text-[#3d2305]', !caenOk);
      }
      if (caenFeedback) caenFeedback.textContent = caenOk
        ? 'Codul apare în lista celor 224 de activități eligibile.'
        : caen.length < 4 ? 'Introdu un cod CAEN Rev. 3 format din 4 cifre.' : 'Codul nu apare în lista activităților eligibile din Anexa nr. 1.';

      const financialTitle = checker.querySelector('[data-industry-financial-title]');
      const financialNote = checker.querySelector('[data-industry-financial-note]');
      if (company === 'new') {
        if (financialTitle) financialTitle.textContent = 'Capital social și condiția asociaților';
        if (financialNote) financialNote.textContent = 'Minimum 100.000 lei vărsat și istoric eligibil';
      } else {
        if (financialTitle) financialTitle.textContent = 'Rentabilitate și capitaluri pozitive';
        if (financialNote) financialNote.textContent = 'Rentabilitate > 0 într-unul din ultimii 3 ani';
      }

      const progress = checker.querySelector('[data-industry-progress]');
      if (progress) progress.style.background = `conic-gradient(${readiness === 100 ? '#a7d46f' : '#e8a96a'} ${readiness}%, rgba(255,255,255,.12) 0)`;

      let status = 'Potențial eligibil';
      let message = 'Profilul introdus îndeplinește reperele principale. Următorul pas este verificarea produsului CPA, a documentelor și a viabilității financiare.';
      if (!notStarted) {
        status = 'Investiția poate fi neeligibilă';
        message = 'Demararea lucrărilor înainte de depunerea cererii elimină întreaga investiție. Verifică orice comandă fermă, contract sau lucrare deja începută.';
      } else if (!caenOk) {
        status = 'Cod CAEN neeligibil sau incomplet';
        message = 'Finanțarea se solicită pentru un singur cod CAEN din Anexa nr. 1. Introdu codul Rev. 3 și verifică produsul CPA rezultat.';
      } else if (!budgetOk) {
        status = 'Investiție sub pragul minim';
        message = 'Schema solicită costuri eligibile fără TVA de minimum 50 milioane lei. Bugetul investiției trebuie redimensionat sau orientat către alt program.';
      } else if (!locationOk) {
        status = 'Locația necesită verificare';
        message = 'Intensitatea regională nu a putut fi stabilită pentru opțiunea selectată. Bucureștiul nu apare în harta anexată, iar localitățile din Ilfov au reguli distincte.';
      } else if (readiness < 100) {
        status = 'Mai sunt condiții de clarificat';
        message = 'Investiția poate avea potențial, dar elementele nebifate trebuie documentate înainte de pregătirea cererii.';
      }
      text('[data-industry-status]', status);
      text('[data-industry-message]', message);
    };

    budgetRange?.addEventListener('input', () => {
      budgetInput.value = budgetRange.value;
      update();
    });
    budgetInput?.addEventListener('input', () => {
      const value = Math.min(500000000, Math.max(10000000, Number(budgetInput.value) || 10000000));
      budgetRange.value = String(value);
      update();
    });
    [...companyInputs, caenInput, locationInput, environmentInput, reductionInput, clusterInput, ...pointInputs, ...conditionInputs]
      .filter(Boolean)
      .forEach((input) => input.addEventListener('input', update));

    update();
  })();
</script>
