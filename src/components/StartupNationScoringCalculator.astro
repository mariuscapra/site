---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section data-sun-scoring class="grain relative mt-8 overflow-hidden rounded-[2rem] bg-[#0b0e0c] text-white shadow-[0_30px_80px_rgba(11,14,12,0.24)]">
  <div class="pointer-events-none absolute -right-32 -top-36 h-[28rem] w-[28rem] rounded-full border-[74px] border-[#55d685]/10"></div>
  <div class="pointer-events-none absolute -bottom-48 -left-36 h-96 w-96 rounded-full bg-[#0b0e0c]/45"></div>

  <header class="relative border-b border-white/10 p-7 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-[#55d685] px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.15em] text-[#0b0e0c]">
          <span class="h-1.5 w-1.5 rounded-full bg-[#0b0e0c]"></span>
          Prescoring Start-Up Nation
        </span>
        <h2 class="display-font mt-5 text-4xl leading-none sm:text-6xl">Calculează punctajul proiectului</h2>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/68">
          Completează cele șase criterii din formularul de finanțare. Scorul și diferența până la pragul minim se actualizează instant.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-2">
        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-center">
          <span class="block text-[9px] font-black uppercase tracking-[0.12em] text-white/40">Prag minim</span>
          <strong class="mt-1 block text-2xl text-[#55d685]">50 p.</strong>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-center">
          <span class="block text-[9px] font-black uppercase tracking-[0.12em] text-white/40">Maximum</span>
          <strong class="mt-1 block text-2xl text-[#55d685]">100 p.</strong>
        </div>
      </div>
    </div>
  </header>

  <div class="relative grid xl:grid-cols-[1.08fr_0.92fr]">
    <div class="border-b border-white/10 p-7 sm:p-10 xl:border-b-0 xl:border-r">
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="rounded-2xl border border-white/12 bg-white/5 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[#55d685]/12 text-xs font-black text-[#55d685]">A</span>
            <span>
              <strong class="block text-sm">Aportul propriu</strong>
              <span class="mt-0.5 block text-[10px] text-white/42">maximum 20 puncte</span>
            </span>
          </span>
          <span class="mt-5 flex items-center justify-between gap-4 text-xs font-bold text-white/68">
            <span>Procent din valoarea eligibilă</span>
            <strong data-sun-contribution-label class="text-lg text-[#55d685]">10%</strong>
          </span>
          <input data-sun-contribution type="range" min="10" max="30" step="0.1" value="10" class="mt-3 w-full accent-[#55d685]" />
          <div class="mt-2 flex justify-between text-[9px] font-bold text-white/30"><span>10%</span><span>15%</span><span>20%+</span></div>
          <p data-sun-contribution-feedback class="mt-3 text-[10px] leading-5 text-white/45">10% aport propriu — 0 p.</p>
        </label>

        <label class="rounded-2xl border border-white/12 bg-white/5 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[#55d685]/12 text-xs font-black text-[#55d685]">B</span>
            <span>
              <strong class="block text-sm">Investiția în echipamente</strong>
              <span class="mt-0.5 block text-[10px] text-white/42">maximum 20 puncte</span>
            </span>
          </span>
          <span class="mt-5 flex items-center justify-between gap-4 text-xs font-bold text-white/68">
            <span>Pondere în cheltuielile eligibile</span>
            <strong data-sun-equipment-label class="text-lg text-[#55d685]">0%</strong>
          </span>
          <input data-sun-equipment type="range" min="0" max="100" step="0.1" value="0" class="mt-3 w-full accent-[#55d685]" />
          <div class="mt-2 flex justify-between text-[9px] font-bold text-white/30"><span>0%</span><span>&gt;20%</span><span>&gt;30%</span><span>&gt;40%</span></div>
          <p data-sun-equipment-feedback class="mt-3 text-[10px] leading-5 text-white/45">Pondere de maximum 20% — 0 p.</p>
        </label>

        <label class="rounded-2xl border border-white/12 bg-white/5 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[#55d685]/12 text-xs font-black text-[#55d685]">C</span>
            <span>
              <strong class="block text-sm">Dezvoltare durabilă</strong>
              <span class="mt-0.5 block text-[10px] text-white/42">maximum 20 puncte</span>
            </span>
          </span>
          <span class="mt-5 flex items-center rounded-xl border border-white/12 bg-[#0b0e0c] px-3 focus-within:border-[#55d685]">
            <input data-sun-sustainable type="number" min="0" step="1000" value="0" class="min-w-0 flex-1 bg-transparent py-3 text-base font-extrabold text-white outline-none" />
            <span class="text-[10px] font-bold text-white/38">lei</span>
          </span>
          <p data-sun-sustainable-feedback class="mt-3 text-[10px] leading-5 text-white/45">Sub 10.000 lei — 0 p.</p>
        </label>

        <label class="rounded-2xl border border-white/12 bg-white/5 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[#55d685]/12 text-xs font-black text-[#55d685]">D</span>
            <span>
              <strong class="block text-sm">Debutul în afaceri</strong>
              <span class="mt-0.5 block text-[10px] text-white/42">maximum 10 puncte</span>
            </span>
          </span>
          <select data-sun-business-history class="mt-5 min-h-12 w-full rounded-xl border border-white/12 bg-[#0b0e0c] px-3 text-sm text-white outline-none">
            <option value="0">Asociații au mai avut calitatea de asociați/acționari — 0 p.</option>
            <option value="10">Nu au mai fost asociați/acționari în altă întreprindere — 10 p.</option>
          </select>
        </label>

        <label class="rounded-2xl border border-white/12 bg-white/5 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[#55d685]/12 text-xs font-black text-[#55d685]">E</span>
            <span>
              <strong class="block text-sm">Menținerea locurilor de muncă</strong>
              <span class="mt-0.5 block text-[10px] text-white/42">maximum 10 puncte</span>
            </span>
          </span>
          <select data-sun-jobs class="mt-5 min-h-12 w-full rounded-xl border border-white/12 bg-[#0b0e0c] px-3 text-sm text-white outline-none">
            <option value="0">24 de luni — 0 p.</option>
            <option value="10">30 de luni — 10 p.</option>
          </select>
          <p class="mt-3 text-[10px] leading-5 text-white/42">Crearea a minimum două locuri de muncă rămâne obligatorie; criteriul punctează perioada de menținere.</p>
        </label>

        <label class="rounded-2xl border border-white/12 bg-white/5 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[#55d685]/12 text-xs font-black text-[#55d685]">F</span>
            <span>
              <strong class="block text-sm">Domeniul de activitate</strong>
              <span class="mt-0.5 block text-[10px] text-white/42">maximum 20 puncte</span>
            </span>
          </span>
          <span class="mt-5 flex items-center rounded-xl border border-white/12 bg-[#0b0e0c] px-3 focus-within:border-[#55d685]">
            <input data-sun-caen inputmode="numeric" maxlength="4" placeholder="Cod CAEN Rev. 3" class="min-w-0 flex-1 bg-transparent py-3 text-base font-extrabold tracking-[0.1em] text-white outline-none" />
            <span data-sun-caen-badge class="rounded-full bg-white/8 px-2.5 py-1 text-[9px] font-black uppercase tracking-[0.08em] text-white/48">0 p.</span>
          </span>
          <p data-sun-caen-feedback class="mt-3 text-[10px] leading-5 text-white/45">Introdu codul CAEN format din 4 cifre.</p>
        </label>
      </div>
    </div>

    <aside class="bg-[#0b0e0c]/82 p-7 sm:p-10">
      <div class="sticky top-28">
        <span class="text-[10px] font-black uppercase tracking-[0.16em] text-[#55d685]">Rezultatul proiectului</span>
        <div class="mt-5 flex items-end justify-between gap-5">
          <div>
            <strong data-sun-total class="block text-5xl font-black" aria-live="polite">0</strong>
            <span class="mt-1 block text-xs font-bold text-white/42">din 100 puncte</span>
          </div>
          <div data-sun-ring class="grid h-24 w-24 shrink-0 place-items-center rounded-full p-[7px]" style="background: conic-gradient(#55d685 0%, rgba(255,255,255,.12) 0)">
            <div class="grid h-full w-full place-items-center rounded-full bg-[#0b0e0c] text-sm font-black"><span data-sun-percentage>0%</span></div>
          </div>
        </div>

        <div class="relative mt-8">
          <div class="h-3 overflow-hidden rounded-full bg-white/10">
            <div data-sun-progress class="h-full w-0 rounded-full bg-[#55d685] transition-[width] duration-300"></div>
          </div>
          <div class="pointer-events-none absolute left-1/2 top-0 h-3 w-px bg-white/80"></div>
          <div class="mt-2 flex justify-between text-[9px] font-bold text-white/34"><span>0</span><span>50 · prag minim</span><span>100</span></div>
        </div>

        <div class="mt-6 rounded-2xl border border-[#55d685]/22 bg-[#55d685]/8 p-5">
          <strong data-sun-status class="block text-lg text-[#f3f4f3]">Sub pragul minim</strong>
          <p data-sun-message class="mt-2 text-xs leading-6 text-white/58">Mai sunt necesare 50 de puncte pentru atingerea pragului minim de accesare.</p>
        </div>

        <div class="mt-7">
          <span class="text-[10px] font-black uppercase tracking-[0.14em] text-[#55d685]">Detalierea punctajului</span>
          <ul class="mt-4 grid gap-1 text-xs">
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Aport propriu</span><strong data-sun-row="contribution">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Echipamente</span><strong data-sun-row="equipment">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Dezvoltare durabilă</span><strong data-sun-row="sustainable">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Debut în afaceri</span><strong data-sun-row="business">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Locuri de muncă</span><strong data-sun-row="jobs">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 py-2.5"><span class="text-white/58">Domeniu CAEN</span><strong data-sun-row="caen">0 p.</strong></li>
          </ul>
        </div>

        <div class="mt-7 rounded-2xl border border-[#55d685]/18 bg-[#55d685]/7 p-4 text-[11px] leading-5 text-white/52">
          Atingerea pragului de 50 de puncte permite accesarea, dar nu garantează finanțarea. Proiectele sunt selectate în ordinea descrescătoare a punctajului.
        </div>

        <a href={`${base}/#contact`} class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#55d685] px-6 py-4 text-sm font-extrabold text-[#0b0e0c] transition hover:-translate-y-0.5 hover:bg-[#55d685]">
          Cere verificarea prescoringului
          <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5"></path></svg>
        </a>
        <p class="mt-4 text-center text-[10px] leading-5 text-white/35">Calcul orientativ. Procedura aplicabilă și evaluarea autorității finanțatoare prevalează.</p>
      </div>
    </aside>
  </div>
</section>

<script is:inline>
  (() => {
    const calculator = document.querySelector('[data-sun-scoring]');
    if (!calculator) return;

    const caen20 = new Set('1011,1012,1013,1020,1031,1032,1039,1041,1051,1061,1073,1083,1084,1091,1092,1107,2611,2612,2620,2630,2640,2651'.split(','));
    const caen15 = new Set('1611,1612,1621,1622,1623,1624,1625,1626,1627,1628,1711,1712,1721,1722,1723,1724,1725'.split(','));
    const caen10 = new Set('1042,1052,1062,1071,1072,1081,1082,1085,1086,1089,1310,1320,1330,1391,1392,1393,1394,1395,1396,1399,1410,1421,1422,1423,1424,1429,1511,1512,1520,1811,1812,1910,1920,2011,2012,2013,2014,2015,2016,2017,2020,2030,2041,2042,2051,2059,2060,2110,2120,2211,2212,2221,2222,2223,2224,2225,2226,2311,2312,2313,2314,2315,2320,2331,2332,2341,2342,2343,2344,2345,2351,2352,2361,2362,2363,2364,2365,2366,2370,2391,2399,2410,2420,2431,2432,2433,2434,2441,2442,2443,2444,2445,2446,2451,2452,2453,2454,2511,2512,2521,2522,2540,2551,2552,2553,2561,2562,2563,2591,2592,2593,2594,2599,2652,2660,2670,2711,2712,2720,2731,2732,2733,2740,2751,2752,2790,2811,2812,2813,2814,2815,2821,2822,2823,2824,2825,2829,2830,2841,2842,2891,2892,2893,2894,2895,2896,2897,2899,2910,2920,2931,2932,3011,3012,3020,3031,3032,3091,3092,3099,3100,3211,3212,3213,3220,3230,3240,3250,3291,3299'.split(','));
    const contributionInput = calculator.querySelector('[data-sun-contribution]');
    const equipmentInput = calculator.querySelector('[data-sun-equipment]');
    const sustainableInput = calculator.querySelector('[data-sun-sustainable]');
    const businessInput = calculator.querySelector('[data-sun-business-history]');
    const jobsInput = calculator.querySelector('[data-sun-jobs]');
    const caenInput = calculator.querySelector('[data-sun-caen]');

    const setText = (selector, value) => {
      const element = calculator.querySelector(selector);
      if (element) element.textContent = value;
    };
    const formatPercent = (value) => Number(value).toLocaleString('ro-RO', { maximumFractionDigits: 1 });

    const update = () => {
      const contributionPercent = Math.max(0, Number(contributionInput?.value) || 0);
      const contribution = contributionPercent >= 20 ? 20 : contributionPercent >= 15 ? 15 : contributionPercent >= 11 ? 10 : 0;
      setText('[data-sun-contribution-label]', `${formatPercent(contributionPercent)}%`);
      setText('[data-sun-contribution-feedback]', `${formatPercent(contributionPercent)}% aport propriu — ${contribution} p.`);

      const equipmentPercent = Math.max(0, Number(equipmentInput?.value) || 0);
      const equipment = equipmentPercent > 40 ? 20 : equipmentPercent > 30 ? 15 : equipmentPercent > 20 ? 10 : 0;
      setText('[data-sun-equipment-label]', `${formatPercent(equipmentPercent)}%`);
      setText('[data-sun-equipment-feedback]', `${formatPercent(equipmentPercent)}% în echipamente — ${equipment} p.`);

      const sustainableValue = Math.max(0, Number(sustainableInput?.value) || 0);
      const sustainable = sustainableValue >= 15000 ? 20 : sustainableValue >= 10000 ? 10 : 0;
      setText('[data-sun-sustainable-feedback]', `${sustainableValue.toLocaleString('ro-RO')} lei — ${sustainable} p.`);

      const business = Number(businessInput?.value) || 0;
      const jobs = Number(jobsInput?.value) || 0;
      const caen = String(caenInput?.value ?? '').replace(/\D/g, '').slice(0, 4);
      if (caenInput && caenInput.value !== caen) caenInput.value = caen;
      const caenScore = caen20.has(caen) ? 20 : caen15.has(caen) ? 15 : caen10.has(caen) ? 10 : 0;

      const caenBadge = calculator.querySelector('[data-sun-caen-badge]');
      if (caenBadge) {
        caenBadge.textContent = `${caenScore} p.`;
        caenBadge.classList.toggle('bg-[#55d685]', caenScore > 0);
        caenBadge.classList.toggle('text-[#0b0e0c]', caenScore > 0);
        caenBadge.classList.toggle('bg-white/8', caenScore === 0);
        caenBadge.classList.toggle('text-white/48', caenScore === 0);
      }
      setText(
        '[data-sun-caen-feedback]',
        caen.length < 4
          ? 'Introdu codul CAEN format din 4 cifre.'
          : caenScore > 0
            ? `Codul ${caen} apare în tabelul activităților punctate — ${caenScore} p.`
            : `Codul ${caen} nu apare în tabelul punctat; dacă este eligibil, primește 0 p.`,
      );

      const scores = { contribution, equipment, sustainable, business, jobs, caen: caenScore };
      const total = Object.values(scores).reduce((sum, value) => sum + value, 0);
      const percentage = Math.max(0, Math.min(100, total));
      setText('[data-sun-total]', String(total));
      setText('[data-sun-percentage]', `${percentage}%`);
      Object.entries(scores).forEach(([name, value]) => setText(`[data-sun-row="${name}"]`, `${value} p.`));

      const progress = calculator.querySelector('[data-sun-progress]');
      if (progress) progress.style.width = `${percentage}%`;
      const ring = calculator.querySelector('[data-sun-ring]');
      if (ring) ring.style.background = `conic-gradient(${total >= 50 ? '#55d685' : '#55d685'} ${percentage}%, rgba(255,255,255,.12) 0)`;

      const statusBox = calculator.querySelector('[data-sun-status]')?.parentElement;
      let status = 'Sub pragul minim';
      let message = `Mai sunt necesare ${50 - total} puncte pentru atingerea pragului minim de accesare.`;
      if (total >= 50) {
        status = 'Pragul minim este atins';
        message = `Proiectul are un prescoring de ${total} puncte. Finanțarea depinde de clasamentul final și de bugetul disponibil.`;
      }
      setText('[data-sun-status]', status);
      setText('[data-sun-message]', message);
      if (statusBox) {
        statusBox.classList.toggle('border-[#55d685]/22', total >= 50);
        statusBox.classList.toggle('bg-[#55d685]/8', total >= 50);
        statusBox.classList.toggle('border-[#55d685]/22', total < 50);
        statusBox.classList.toggle('bg-[#55d685]/8', total < 50);
      }
    };

    [contributionInput, equipmentInput, sustainableInput, businessInput, jobsInput, caenInput]
      .filter(Boolean)
      .forEach((input) => input.addEventListener('input', update));

    update();
  })();
</script>
