---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section data-dr12-scoring class="grain relative mt-8 overflow-hidden rounded-[2rem] border border-[#0b0e0c]/10 bg-[#f5f5f3] shadow-[0_30px_80px_rgba(11,14,12,0.16)]">
  <div class="pointer-events-none absolute -right-28 -top-36 h-96 w-96 rounded-full border-[70px] border-[#55d685]/18"></div>
  <div class="pointer-events-none absolute -bottom-56 -left-32 h-96 w-96 rounded-full bg-[#f3f4f3]/55"></div>

  <header class="relative border-b border-[#0b0e0c]/10 p-7 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-[#0b0e0c] px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.15em] text-white">
          <span class="h-1.5 w-1.5 rounded-full bg-[#55d685]"></span>
          Prescoring DR-12
        </span>
        <h2 class="display-font mt-5 text-4xl leading-none text-[#0b0e0c] sm:text-6xl">Calculează punctajul proiectului</h2>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-[#0b0e0c]/64">
          Alege componenta și completează cele șase principii de selecție. Calculatorul aplică automat regulile diferite pentru proprietatea exploatației.
        </p>
      </div>
      <div class="rounded-2xl border border-[#0b0e0c]/10 bg-white/65 px-5 py-4">
        <span class="block text-[9px] font-black uppercase tracking-[0.14em] text-[#0b0e0c]/42">Grilă consultativă</span>
        <strong class="mt-1 block text-xl text-[#0b0e0c]">Maximum 100 puncte</strong>
      </div>
    </div>
  </header>

  <div class="relative grid xl:grid-cols-[1.08fr_0.92fr]">
    <div class="border-b border-[#0b0e0c]/10 p-7 sm:p-10 xl:border-b-0 xl:border-r">
      <fieldset>
        <legend class="text-[10px] font-black uppercase tracking-[0.16em] text-[#0b0e0c]">Alege componenta proiectului</legend>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="dr12-sector" value="vegetal" checked />
            <span class="flex h-full min-h-28 flex-col rounded-2xl border border-[#0b0e0c]/10 bg-white/60 p-5 transition peer-checked:border-[#0b0e0c] peer-checked:bg-[#f3f4f3]">
              <span class="flex items-center justify-between gap-3">
                <strong class="text-base text-[#0b0e0c]">Vegetal / alte sectoare</strong>
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[#0b0e0c] text-sm text-white">V</span>
              </span>
              <span class="mt-2 text-xs leading-5 text-[#0b0e0c]/52">Terenul agricol deținut în proprietate poate aduce maximum 25 p.</span>
            </span>
          </label>
          <label class="cursor-pointer">
            <input class="peer sr-only" type="radio" name="dr12-sector" value="zootehnic" />
            <span class="flex h-full min-h-28 flex-col rounded-2xl border border-[#0b0e0c]/10 bg-white/60 p-5 transition peer-checked:border-[#0b0e0c] peer-checked:bg-[#f3f4f3]">
              <span class="flex items-center justify-between gap-3">
                <strong class="text-base text-[#0b0e0c]">Sector zootehnic</strong>
                <span class="grid h-8 w-8 place-items-center rounded-full bg-[#0b0e0c] text-sm text-white">Z</span>
              </span>
              <span class="mt-2 text-xs leading-5 text-[#0b0e0c]/52">Extinderea clădirilor și terenul în proprietate se pot cumula până la 25 p.</span>
            </span>
          </label>
        </div>
      </fieldset>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <label class="rounded-2xl border border-[#0b0e0c]/10 bg-white/70 p-5 focus-within:border-[#0b0e0c]/55">
          <span class="flex items-center gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#0b0e0c]/10 text-[10px] font-black text-[#0b0e0c]">01</span>
            <span>
              <strong class="block text-sm text-[#0b0e0c]">Nivelul de calificare</strong>
              <span class="mt-0.5 block text-[10px] text-[#0b0e0c]/42">Opțiunile nu se cumulează</span>
            </span>
          </span>
          <select data-dr12-points="qualification" class="mt-4 min-h-12 w-full rounded-xl border border-[#0b0e0c]/12 bg-[#f5f5f3] px-3 text-sm font-semibold text-[#0b0e0c] outline-none">
            <option value="0">Fără calificare punctabilă — 0 p.</option>
            <option value="10">Liceu agricol / postliceală / curs min. nivel I — 10 p.</option>
            <option value="15">Studii superioare relevante — 15 p.</option>
          </select>
        </label>

        <label class="rounded-2xl border border-[#0b0e0c]/10 bg-white/70 p-5 focus-within:border-[#0b0e0c]/55">
          <span class="flex items-center gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#0b0e0c]/10 text-[10px] font-black text-[#0b0e0c]">02</span>
            <span>
              <strong class="block text-sm text-[#0b0e0c]">Structură asociativă</strong>
              <span class="mt-0.5 block text-[10px] text-[#0b0e0c]/42">Opțiunile nu se cumulează</span>
            </span>
          </span>
          <select data-dr12-points="association" class="mt-4 min-h-12 w-full rounded-xl border border-[#0b0e0c]/12 bg-[#f5f5f3] px-3 text-sm font-semibold text-[#0b0e0c] outline-none">
            <option value="0">Nu face parte — 0 p.</option>
            <option value="5">Membru cooperator asociat, Legea 566/2004 — 5 p.</option>
            <option value="10">Membru într-o structură cu rol economic — 10 p.</option>
            <option value="15">Membru cooperator acționar; cooperativă cu procesare/abatorizare — 15 p.</option>
          </select>
        </label>

        <div class="rounded-2xl border border-[#0b0e0c]/10 bg-white/70 p-5 sm:col-span-2">
          <span class="flex items-center gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#0b0e0c]/10 text-[10px] font-black text-[#0b0e0c]">03</span>
            <span>
              <strong class="block text-sm text-[#0b0e0c]">Proprietatea exploatației</strong>
              <span data-dr12-ownership-note class="mt-0.5 block text-[10px] text-[#0b0e0c]/42">Maximum 25 p., proporțional cu terenul agricol deținut în proprietate</span>
            </span>
          </span>

          <label data-dr12-building-row class="mt-5 hidden cursor-pointer items-start gap-3 rounded-xl border border-[#0b0e0c]/12 bg-[#f3f4f3]/75 p-4">
            <input data-dr12-building class="mt-0.5 h-5 w-5 shrink-0 accent-[#0b0e0c]" type="checkbox" />
            <span>
              <strong class="block text-xs text-[#0b0e0c]">Proiectul extinde clădiri zootehnice aflate în proprietate — 20 p.</strong>
              <span class="mt-1 block text-[10px] leading-5 text-[#0b0e0c]/48">Simpla modernizare fără extindere nu primește acest punctaj.</span>
            </span>
          </label>

          <label class="mt-5 block">
            <span class="flex items-center justify-between gap-4 text-xs font-bold text-[#0b0e0c]/70">
              <span>Ponderea terenului agricol deținut în proprietate</span>
              <strong data-dr12-land-label class="text-base text-[#0b0e0c]">0%</strong>
            </span>
            <input data-dr12-land type="range" min="0" max="100" step="1" value="0" class="mt-3 w-full accent-[#0b0e0c]" />
            <span class="mt-2 flex justify-between text-[9px] font-bold uppercase tracking-[0.1em] text-[#0b0e0c]/32"><span>0%</span><span>100%</span></span>
          </label>
        </div>

        <label class="rounded-2xl border border-[#0b0e0c]/10 bg-white/70 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#0b0e0c]/10 text-[10px] font-black text-[#0b0e0c]">04</span>
            <span>
              <strong class="block text-sm text-[#0b0e0c]">Agricultură de precizie</strong>
              <span class="mt-0.5 block text-[10px] text-[#0b0e0c]/42">Minimum 10% din valoarea eligibilă</span>
            </span>
          </span>
          <span class="mt-5 flex items-center justify-between text-xs font-bold text-[#0b0e0c]/70">
            <span>Pondere în proiect</span>
            <strong data-dr12-precision-label class="text-base text-[#0b0e0c]">0%</strong>
          </span>
          <input data-dr12-precision type="range" min="0" max="50" step="1" value="0" class="mt-3 w-full accent-[#0b0e0c]" />
          <p data-dr12-precision-feedback class="mt-3 text-[10px] leading-5 text-[#0b0e0c]/45">Sub pragul de 10% — 0 p.</p>
        </label>

        <label class="rounded-2xl border border-[#0b0e0c]/10 bg-white/70 p-5">
          <span class="flex items-center gap-3">
            <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#0b0e0c]/10 text-[10px] font-black text-[#0b0e0c]">05</span>
            <span>
              <strong class="block text-sm text-[#0b0e0c]">Asigurarea exploatației</strong>
              <span class="mt-0.5 block text-[10px] text-[#0b0e0c]/42">Punctaj proporțional, maximum 10 p.</span>
            </span>
          </span>
          <span class="mt-5 flex items-center justify-between text-xs font-bold text-[#0b0e0c]/70">
            <span>Gradul de acoperire</span>
            <strong data-dr12-insurance-label class="text-base text-[#0b0e0c]">0%</strong>
          </span>
          <input data-dr12-insurance type="range" min="0" max="100" step="1" value="0" class="mt-3 w-full accent-[#0b0e0c]" />
          <p class="mt-3 text-[10px] leading-5 text-[#0b0e0c]/45">Pentru ferme mixte se ia în calcul obiectivul asigurat cu acoperirea cea mai mare.</p>
        </label>

        <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-[#0b0e0c]/10 bg-white/70 p-5 sm:col-span-2">
          <input data-dr12-first-feadr class="mt-0.5 h-5 w-5 shrink-0 accent-[#0b0e0c]" type="checkbox" />
          <span>
            <span class="flex items-center gap-3">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[#0b0e0c]/10 text-[10px] font-black text-[#0b0e0c]">06</span>
              <strong class="text-sm text-[#0b0e0c]">Solicitantul accesează pentru prima dată sprijin FEADR pentru investiții — 20 p.</strong>
            </span>
            <span class="mt-2 block pl-10 text-[10px] leading-5 text-[#0b0e0c]/45">Sprijinul forfetar prin sM 6.1 și DR-30 nu este considerat intervenție de investiții pentru acest criteriu.</span>
          </span>
        </label>
      </div>
    </div>

    <aside class="bg-[#0b0e0c] p-7 text-white sm:p-10">
      <div class="sticky top-28">
        <span class="text-[10px] font-black uppercase tracking-[0.16em] text-[#55d685]">Prescoring orientativ</span>
        <div class="mt-5 flex items-end justify-between gap-5">
          <div>
            <strong data-dr12-total class="block text-5xl font-black" aria-live="polite">0</strong>
            <span class="mt-1 block text-xs font-bold text-white/42">din 100 puncte</span>
          </div>
          <div data-dr12-score-ring class="grid h-24 w-24 shrink-0 place-items-center rounded-full p-[7px]" style="background: conic-gradient(#55d685 0%, rgba(255,255,255,.12) 0)">
            <div class="grid h-full w-full place-items-center rounded-full bg-[#0b0e0c] text-sm font-black"><span data-dr12-ring-value>0%</span></div>
          </div>
        </div>

        <div class="relative mt-8">
          <div class="h-3 overflow-hidden rounded-full bg-white/10">
            <div data-dr12-score-bar class="h-full w-0 rounded-full bg-[#55d685] transition-[width] duration-300"></div>
          </div>
          <div class="pointer-events-none absolute left-[45%] top-0 h-3 w-px bg-white/75"></div>
          <div class="pointer-events-none absolute left-[75%] top-0 h-3 w-px bg-white/75"></div>
          <div class="mt-2 grid grid-cols-[45fr_30fr_25fr] text-[9px] font-bold text-white/36">
            <span>0</span>
            <span>45 · prag minim</span>
            <span class="text-right">75 · etapa I</span>
          </div>
        </div>

        <div class="mt-6 rounded-2xl border border-[#55d685]/20 bg-[#55d685]/8 p-5">
          <strong data-dr12-result-title class="block text-lg text-[#f3f4f3]">Sub pragul minim</strong>
          <p data-dr12-result-message class="mt-2 text-xs leading-6 text-white/58">Mai sunt criterii de analizat pentru atingerea pragului minim de 45 de puncte.</p>
        </div>

        <div class="mt-7">
          <div class="flex items-center justify-between">
            <span class="text-[10px] font-black uppercase tracking-[0.14em] text-[#55d685]">Detalierea punctajului</span>
            <span data-dr12-sector-label class="text-[10px] text-white/35">Vegetal / alte sectoare</span>
          </div>
          <ul class="mt-4 grid gap-1 text-xs">
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Calificare</span><strong data-dr12-row="qualification">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Structură asociativă</span><strong data-dr12-row="association">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Proprietatea exploatației</span><strong data-dr12-row="ownership">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Agricultură de precizie</span><strong data-dr12-row="precision">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 border-b border-white/8 py-2.5"><span class="text-white/58">Asigurare</span><strong data-dr12-row="insurance">0 p.</strong></li>
            <li class="flex items-center justify-between gap-4 py-2.5"><span class="text-white/58">Prima accesare FEADR</span><strong data-dr12-row="feadr">0 p.</strong></li>
          </ul>
        </div>

        <div class="mt-7 rounded-2xl border border-[#55d685]/20 bg-[#55d685]/7 p-4 text-[11px] leading-5 text-white/52">
          Punctajul se declară pe propria răspundere și trebuie susținut cu documentele cerute pentru fiecare criteriu. Selectarea unei opțiuni nu confirmă automat acceptarea ei de către AFIR.
        </div>

        <a href={`${base}/#contact`} class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#55d685] px-6 py-4 text-sm font-extrabold text-[#0b0e0c] transition hover:-translate-y-0.5 hover:bg-[#55d685]">
          Verifică documentele pentru punctaj
          <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5"></path></svg>
        </a>
        <p class="mt-4 text-center text-[10px] leading-5 text-white/35">Calcul orientativ realizat pe baza proiectului de ghid DR-12. Ghidul final și evaluarea AFIR prevalează.</p>
      </div>
    </aside>
  </div>
</section>

<script is:inline>
  (() => {
    const calculator = document.querySelector('[data-dr12-scoring]');
    if (!calculator) return;

    const sectorInputs = [...calculator.querySelectorAll('input[name="dr12-sector"]')];
    const pointInputs = [...calculator.querySelectorAll('[data-dr12-points]')];
    const landInput = calculator.querySelector('[data-dr12-land]');
    const precisionInput = calculator.querySelector('[data-dr12-precision]');
    const insuranceInput = calculator.querySelector('[data-dr12-insurance]');
    const buildingInput = calculator.querySelector('[data-dr12-building]');
    const firstFeadrInput = calculator.querySelector('[data-dr12-first-feadr]');
    const buildingRow = calculator.querySelector('[data-dr12-building-row]');

    const setText = (selector, value) => {
      const element = calculator.querySelector(selector);
      if (element) element.textContent = value;
    };
    const pointValue = (name) => Number(calculator.querySelector(`[data-dr12-points="${name}"]`)?.value) || 0;
    const formatPoints = (value) => Number.isInteger(value) ? String(value) : value.toFixed(1).replace('.', ',');

    const update = () => {
      const sector = sectorInputs.find((input) => input.checked)?.value ?? 'vegetal';
      const isZootechnic = sector === 'zootehnic';
      const landPercent = Math.max(0, Math.min(100, Number(landInput?.value) || 0));
      const precisionPercent = Math.max(0, Number(precisionInput?.value) || 0);
      const insurancePercent = Math.max(0, Math.min(100, Number(insuranceInput?.value) || 0));

      if (buildingRow) {
        buildingRow.classList.toggle('hidden', !isZootechnic);
        buildingRow.classList.toggle('flex', isZootechnic);
      }

      const qualification = pointValue('qualification');
      const association = pointValue('association');
      const ownership = isZootechnic
        ? (buildingInput?.checked ? 20 : 0) + (landPercent / 100) * 5
        : (landPercent / 100) * 25;
      const precision = precisionPercent >= 10 ? 15 : 0;
      const insurance = (insurancePercent / 100) * 10;
      const feadr = firstFeadrInput?.checked ? 20 : 0;
      const total = qualification + association + ownership + precision + insurance + feadr;
      const roundedTotal = Math.round(total * 10) / 10;
      const percentage = Math.min(100, roundedTotal);

      setText('[data-dr12-land-label]', `${landPercent}%`);
      setText('[data-dr12-precision-label]', `${precisionPercent}%`);
      setText('[data-dr12-insurance-label]', `${insurancePercent}%`);
      setText('[data-dr12-precision-feedback]', precision
        ? 'Pragul de minimum 10% este atins — 15 p.'
        : 'Sub pragul de 10% — 0 p.');
      setText('[data-dr12-ownership-note]', isZootechnic
        ? 'Maximum 25 p.: extinderea clădirilor 20 p. + terenul în proprietate maximum 5 p.'
        : 'Maximum 25 p., proporțional cu terenul agricol deținut în proprietate');
      setText('[data-dr12-sector-label]', isZootechnic ? 'Sector zootehnic' : 'Vegetal / alte sectoare');

      const scores = { qualification, association, ownership, precision, insurance, feadr };
      Object.entries(scores).forEach(([name, value]) => setText(`[data-dr12-row="${name}"]`, `${formatPoints(value)} p.`));
      setText('[data-dr12-total]', formatPoints(roundedTotal));
      setText('[data-dr12-ring-value]', `${Math.round(percentage)}%`);

      const scoreBar = calculator.querySelector('[data-dr12-score-bar]');
      if (scoreBar) scoreBar.style.width = `${percentage}%`;
      const scoreRing = calculator.querySelector('[data-dr12-score-ring]');
      if (scoreRing) scoreRing.style.background = `conic-gradient(${roundedTotal >= 45 ? '#55d685' : '#55d685'} ${percentage}%, rgba(255,255,255,.12) 0)`;

      let title = 'Sub pragul minim';
      let message = `Mai sunt necesare ${formatPoints(Math.max(0, 45 - roundedTotal))} puncte pentru pragul minim de 45.`;
      if (roundedTotal >= 75) {
        title = 'Pragul primei etape este atins';
        message = 'Prescoring-ul este de minimum 75 de puncte, pragul prevăzut pentru prima etapă lunară în proiectul de ghid.';
      } else if (roundedTotal >= 45) {
        title = 'Pragul minim este atins';
        message = `Prescoring-ul trece pragul minim de 45 de puncte. Mai sunt ${formatPoints(75 - roundedTotal)} puncte până la pragul primei etape.`;
      }
      setText('[data-dr12-result-title]', title);
      setText('[data-dr12-result-message]', message);
    };

    [...sectorInputs, ...pointInputs, landInput, precisionInput, insuranceInput, buildingInput, firstFeadrInput]
      .filter(Boolean)
      .forEach((input) => input.addEventListener('input', update));

    update();
  })();
</script>
