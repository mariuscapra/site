---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Marius Capră | Fonduri nerambursabile & Audit de mediu',
  description = 'Consultanță pentru programe de stat, fonduri europene și audit de mediu. De la eligibilitate și scriere până la implementare și conformitate.',
} = Astro.props;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0B6B49" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ro_RO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.add('has-js');</script>
  </head>
  <body>
    <slot />
  </body>
</html>
