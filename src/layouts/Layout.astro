---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Marius Capră | Consultanță fonduri europene & Audit de mediu',
  description = 'Consultanță pentru identificarea finanțării, verificarea eligibilității, scrierea și implementarea proiectelor, achiziții și audit de mediu.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F2233" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ro_RO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/logo.svg`} />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.add('has-js');</script>
  </head>
  <body>
    <div class="site-backdrop" aria-hidden="true"></div>
    <slot />
  </body>
</html>
