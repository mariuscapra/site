---
import Layout from '../layouts/Layout.astro';
import { fundingPrograms, fundingStatusStyles } from '../data/fundingPrograms';

const workPhases = [
  {
    number: '01',
    title: 'Clarificăm',
    text: 'Ideea, eligibilitatea și riscurile.',
    result: 'Știi dacă merită să continui.',
    color: 'bg-[#7eb99a] text-[#0f2233]',
  },
  {
    number: '02',
    title: 'Construim',
    text: 'Strategia, bugetul și dosarul.',
    result: 'Ai un proiect coerent și pregătit.',
    color: 'bg-[#7eb99a] text-[#0f2233]',
  },
  {
    number: '03',
    title: 'Implementăm',
    text: 'Contractarea, achizițiile și raportarea.',
    result: 'Duci investiția la capăt controlat.',
    color: 'bg-[#7eb99a] text-[#0f2233]',
  },
];

const servicePaths = [
  {
    number: '01',
    label: 'Caut o oportunitate',
    title: 'Găsește finanțarea potrivită',
    text: 'Explorează programele pregătite în format clar și verifică rapid cui se adresează.',
    action: 'Vezi programele',
    href: '#lista-programe',
  },
  {
    number: '02',
    label: 'Am o idee de investiție',
    title: 'Verifică eligibilitatea proiectului',
    text: 'Pornim de la profil, investiție și buget pentru a vedea dacă merită continuată pregătirea.',
    action: 'Cum colaborăm',
    href: '#proces',
  },
  {
    number: '03',
    label: 'Am nevoie de conformare',
    title: 'Audit și obligații de mediu',
    text: 'Transformă cerințele, documentele și riscurile într-un plan de acțiune ușor de urmărit.',
    action: 'Descoperă auditul',
    href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/audit-de-mediu/`,
  },
];

const fundingStatuses = ['Toate', ...new Set(fundingPrograms.map((program) => program.status))];

const expertisePillars = [
  {
    eyebrow: 'Experiență acumulată',
    metric: '5+',
    unit: 'ani',
    title: 'Fonduri europene',
    text: 'Experiență practică de la analiza oportunității și scriere până la contractare, achiziții și implementare.',
  },
  {
    eyebrow: 'Rol actual',
    metric: '2023',
    unit: '— prezent',
    title: 'Cercetător în economie',
    text: 'Activitate de cercetare în cadrul Academiei de Studii Economice din București, cu accent pe sustenabilitate.',
  },
  {
    eyebrow: 'Calificări profesionale',
    metric: '2',
    unit: 'specializări',
    title: 'Mediu & achiziții',
    text: 'Auditor de mediu și expert achiziții publice, competențe aplicabile direct proiectelor finanțate.',
  },
];

interface Partner {
  name: string;
  logo: string;
  role: string;
  description: string;
  services: string[];
  url?: string;
}

// Logo-urile vor fi adăugate aici pe măsură ce sunt primite.
const partners: Partner[] = [
  {
    name: 'Nexum Energy',
    logo: 'images/partners/nexum-energy.jpg',
    role: 'Partener tehnic — energie verde',
    description: 'Specialist în soluții fotovoltaice, Nexum Energy asigură componenta tehnică a proiectelor: de la consultanță și configurarea soluției până la furnizarea echipamentelor și montajul complet al sistemelor.',
    services: ['Soluții fotovoltaice', 'Furnizare echipamente', 'Montaj specializat'],
  },
  {
    name: 'ImportMAG',
    logo: 'images/partners/importmag.jpg',
    role: 'Partener tehnic — echipamente și utilaje',
    description: 'ImportMAG susține implementarea investițiilor prin consultanță tehnică și industrială, identificarea soluțiilor potrivite și furnizarea de echipamente și utilaje tehnologice adaptate cerințelor fiecărui proiect.',
    services: ['Consultanță tehnică', 'Soluții industriale', 'Furnizare echipamente și utilaje'],
  },
  {
    name: 'ADN MEDIA',
    logo: 'images/partners/adn-media.png',
    role: 'Partener de implementare — informare și publicitate',
    description: 'ADN MEDIA asigură serviciile de promovare și comunicare necesare proiectelor finanțate, contribuind la creșterea vizibilității investițiilor și la îndeplinirea cerințelor de informare și publicitate din etapa de implementare.',
    services: ['Promovarea proiectelor', 'Vizibilitate și comunicare', 'Informare și publicitate'],
  },
  {
    name: 'FinAudit ESG',
    logo: 'images/partners/finaudit-esg.png',
    role: 'Partener specializat — audit și ESG',
    description: 'FinAudit ESG oferă servicii specializate de audit financiar pentru proiecte, verificarea cheltuielilor și auditarea implementării, completate de evaluări ESG relevante pentru investiții responsabile și sustenabile.',
    services: ['Audit financiar proiecte', 'Auditarea proiectelor', 'Audit ESG'],
    url: 'https://finauditesg.ro/',
  },
];

const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <header id="site-header" class="fixed inset-x-0 top-0 z-50 border-b border-[#0f2233]/10 bg-[#ffffff]/90 backdrop-blur-xl transition-shadow duration-300">
    <div class="mx-auto flex h-20 max-w-[1240px] items-center justify-between px-5 sm:px-8">
      <a href="#top" class="flex items-center gap-3" aria-label="Marius Capră - Acasă">
        <img src={`${base}/logo.svg`} alt="" class="h-11 w-11 transition duration-300 hover:rotate-3 hover:scale-105" width="44" height="44" />
        <span class="leading-none">
          <strong class="block text-[15px] font-extrabold tracking-[0.18em] text-[#0f2233]">CAPRĂ</strong>
          <span class="mt-1 block text-[10px] font-semibold uppercase tracking-[0.16em] text-[#0f2233]">Fonduri & Mediu</span>
        </span>
      </a>

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Navigare principală">
        <a data-nav-link data-nav-target="fonduri" data-funding-link class="rounded-full px-4 py-2.5 text-sm font-semibold text-[#0f2233]/72 transition hover:bg-[#f5f7f6] hover:text-[#0f2233]" href="#lista-programe">Programe</a>
        <a class="rounded-full px-4 py-2.5 text-sm font-semibold text-[#0f2233]/72 transition hover:bg-[#f5f7f6] hover:text-[#0f2233]" href={`${base}/audit-de-mediu/`}>Audit de mediu</a>
        <a data-nav-link data-nav-target="despre" class="rounded-full px-4 py-2.5 text-sm font-semibold text-[#0f2233]/72 transition hover:bg-[#f5f7f6] hover:text-[#0f2233]" href="#despre">Expertiză</a>
        <a data-nav-link data-nav-target="parteneri" class="rounded-full px-4 py-2.5 text-sm font-semibold text-[#0f2233]/72 transition hover:bg-[#f5f7f6] hover:text-[#0f2233]" href="#parteneri">Parteneri</a>
        <a class="rounded-full px-4 py-2.5 text-sm font-semibold text-[#0f2233]/72 transition hover:bg-[#f5f7f6] hover:text-[#0f2233]" href={`${base}/intrebari-frecvente/`}>Întrebări</a>
      </nav>

      <div class="hidden lg:block">
        <a href="#contact" class="group inline-flex items-center gap-2 rounded-full bg-[#0f2233] px-5 py-3 text-sm font-extrabold text-white shadow-[0_10px_25px_rgba(15,34,51,0.2)] transition hover:-translate-y-0.5 hover:bg-[#0f2233]">
          Verifică proiectul
          <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current transition group-hover:translate-x-1" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
        </a>
      </div>

      <button id="menu-button" class="grid h-11 w-11 place-items-center rounded-full border border-[#0f2233]/15 bg-white/70 text-[#0f2233] transition hover:border-[#0f2233]/40 hover:bg-[#f5f7f6] lg:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Deschide meniul">
        <svg data-menu-icon aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden border-t border-[#0f2233]/10 bg-[#ffffff]/98 px-5 py-5 shadow-xl lg:hidden">
      <nav class="mx-auto grid max-w-[1240px] gap-1" aria-label="Navigare mobilă">
        <a data-funding-link class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]" href="#lista-programe">Programe de finanțare</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]" href={`${base}/audit-de-mediu/`}>Audit de mediu</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]" href="#despre">Expertiză</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]" href="#parteneri">Parteneri</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]" href={`${base}/intrebari-frecvente/`}>Întrebări frecvente</a>
        <a class="mt-2 rounded-xl bg-[#0f2233] px-4 py-3 text-center font-extrabold text-white" href="#contact">Verifică proiectul</a>
      </nav>
    </div>
    <div class="absolute inset-x-0 bottom-0 h-[2px] bg-[#0f2233]/6"><span id="scroll-progress" class="block h-full w-0 bg-[#7eb99a]"></span></div>
  </header>

  <main id="top">
    <section data-nav-section="top" class="vibrant-hero relative overflow-hidden pb-20 pt-32 sm:pb-28 sm:pt-40">
      <div class="hero-orb absolute -left-28 top-14 h-80 w-80 rounded-full bg-[#7eb99a]/20 blur-3xl"></div>

      <div class="relative mx-auto grid max-w-[1240px] items-center gap-16 px-5 sm:px-8 lg:grid-cols-[1.06fr_0.94fr] lg:gap-20">
        <div>
          <div data-reveal class="mb-7 inline-flex items-center gap-3 rounded-full border border-[#0f2233]/18 bg-white/85 px-4 py-2 text-[10px] font-extrabold uppercase tracking-[0.17em] text-[#0f2233] shadow-sm sm:text-xs">
            <span class="pulse-dot h-2 w-2 rounded-full bg-[#7eb99a] ring-4 ring-[#7eb99a]/25"></span>
            Consultanță pentru investiții finanțate
          </div>
          <h1 data-reveal data-reveal-delay="1" class="display-font max-w-[800px] text-[clamp(3.1rem,7.4vw,7rem)] leading-[0.98] text-[#0f2233] sm:leading-[0.91]">
            Transformă investiția într-un proiect <span class="hero-highlight">finanțabil.</span>
          </h1>
          <p data-reveal data-reveal-delay="2" class="mt-8 max-w-2xl text-lg leading-8 text-[#0f2233]/70 sm:text-xl">
            Sunt <strong class="font-extrabold text-[#0f2233]">Marius Capră</strong>. Te ajut să alegi programul potrivit, să pregătești proiectul și să controlezi implementarea — cu decizii clare, buget realist și atenție la conformitate.
          </p>
          <div data-reveal data-reveal-delay="3" class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="#contact" class="group inline-flex items-center justify-center gap-2 rounded-full bg-[#0f2233] px-7 py-4 font-extrabold text-white shadow-[0_16px_35px_rgba(15,34,51,0.24)] transition hover:-translate-y-1 hover:bg-[#0f2233]">
              Verifică eligibilitatea
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-5 w-5 fill-none stroke-current transition group-hover:translate-x-1" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
            </a>
            <a data-funding-link href="#lista-programe" class="inline-flex items-center justify-center gap-2 rounded-full border border-[#0f2233]/18 bg-white/80 px-7 py-4 font-bold text-[#0f2233] transition hover:-translate-y-1 hover:border-[#0f2233] hover:bg-white hover:text-[#0f2233]">
              Vezi programele
              <span aria-hidden="true">↓</span>
            </a>
          </div>
        </div>

        <div data-reveal data-reveal-delay="2" class="mx-auto w-full max-w-[520px] lg:mx-0 lg:ml-auto">
          <div class="relative">
            <div class="absolute -inset-3 rounded-[2.35rem] bg-[#7eb99a]"></div>
            <div class="soft-shadow group relative overflow-hidden rounded-[2rem] border-[7px] border-white bg-[#f5f7f6]">
              <img src={`${base}/images/marius-capra.jpg`} alt="Marius Capră, consultant în fonduri nerambursabile și auditor de mediu" class="aspect-[4/5] w-full object-cover object-[50%_35%] transition duration-700 group-hover:scale-[1.025]" width="1500" height="1500" fetchpriority="high" />
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-[#0f2233]/95 via-[#0f2233]/72 to-transparent px-7 pb-7 pt-28 text-white sm:px-9 sm:pb-9">
                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#7eb99a]">Fonduri • Economie • Mediu</p>
                <p class="mt-2 max-w-sm text-lg font-bold leading-snug">Perspectivă completă pentru decizii mai bune.</p>
              </div>
            </div>
            <div class="absolute -bottom-6 -left-3 rounded-2xl border border-[#0f2233]/10 bg-[#ffffff] p-4 shadow-xl sm:-left-10 sm:p-5">
              <span class="text-[10px] font-black uppercase tracking-[0.15em] text-[#0f2233]">Experiență</span>
              <div class="mt-1 flex items-end gap-2"><strong class="display-font text-5xl leading-none text-[#0f2233]">5+</strong><span class="mb-1 text-xs font-bold text-[#0f2233]/72">ani în fonduri europene</span></div>
            </div>
            <a href="https://www.linkedin.com/in/marius-capră-83381919b?utm_source=share_via&amp;utm_content=profile&amp;utm_medium=member_ios" target="_blank" rel="noreferrer" class="group absolute -right-2 top-6 grid h-14 w-14 place-items-center rounded-2xl bg-[#0f2233] text-white shadow-[0_14px_30px_rgba(15,34,51,0.3)] transition hover:-translate-y-1 hover:scale-105 hover:bg-[#0f2233] sm:-right-7" aria-label="Vezi profilul LinkedIn al lui Marius Capră">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 fill-current"><path d="M6.5 8.3H3V21h3.5V8.3ZM4.75 3A2.05 2.05 0 1 0 4.8 7.1 2.05 2.05 0 0 0 4.75 3ZM21 13.7c0-3.82-2.04-5.6-4.76-5.6-2.2 0-3.18 1.2-3.73 2.05V8.3H9V21h3.51v-6.3c0-1.66.32-3.27 2.38-3.27 2.03 0 2.06 1.9 2.06 3.38V21H21v-7.3Z" /></svg>
            </a>
          </div>
          <a href="https://www.linkedin.com/in/marius-capră-83381919b?utm_source=share_via&amp;utm_content=profile&amp;utm_medium=member_ios" target="_blank" rel="noreferrer" class="mt-11 flex items-center justify-center gap-2 text-sm font-extrabold text-[#0f2233] transition hover:text-[#0f2233]">
            Vezi experiența mea pe LinkedIn
            <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
          </a>
        </div>
      </div>
    </section>

    <section aria-label="Repere profesionale" class="relative z-10 -mt-6 px-5 sm:-mt-8 sm:px-8">
      <div class="soft-shadow mx-auto grid max-w-[1120px] overflow-hidden rounded-[1.75rem] bg-[#0f2233] text-white sm:grid-cols-3">
        <div class="border-b border-white/12 p-5 sm:border-b-0 sm:border-r sm:p-6">
          <strong class="display-font block text-4xl text-[#7eb99a]">5+ ani</strong><span class="mt-1 block text-xs font-bold text-white/76">experiență în fonduri europene</span>
        </div>
        <div class="border-b border-white/12 p-5 sm:border-b-0 sm:border-r sm:p-6">
          <strong class="display-font block text-3xl text-[#7eb99a] sm:text-4xl">Autorizat ANC</strong><span class="mt-1 block text-xs font-bold leading-5 text-white/76">Expert achiziții publice și audit de mediu</span>
        </div>
        <div class="p-5 sm:p-6">
          <strong class="display-font block text-3xl text-[#7eb99a] sm:text-4xl">Cercetător</strong><span class="mt-1 block text-xs font-bold text-white/76">în economie · activitate în desfășurare</span>
        </div>
      </div>
    </section>

    <section id="servicii" class="py-20 sm:py-28">
      <div class="mx-auto max-w-[1240px] px-5 sm:px-8">
        <div data-reveal class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-[#0f2233]">Alege punctul de pornire</p>
            <h2 class="display-font mt-4 text-4xl leading-none text-[#0f2233] sm:text-6xl">Cu ce te pot ajuta acum?</h2>
          </div>
          <p class="max-w-xl text-sm leading-7 text-[#0f2233]/72">Nu trebuie să cunoști programul sau documentele. Alege situația care seamănă cel mai mult cu nevoia ta.</p>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {servicePaths.map((service, index) => (
            <a href={service.href} data-reveal data-reveal-delay={String(index)} class:list={[
              'group relative flex min-h-60 flex-col overflow-hidden rounded-[2rem] p-7 text-[#0f2233] transition duration-500 hover:-translate-y-2 hover:shadow-[0_26px_60px_rgba(15,34,51,0.16)] sm:p-8',
              index === 0 && 'bg-[#7eb99a]',
              index === 1 && 'bg-[#0f2233] text-white',
              index === 2 && 'bg-[#7eb99a]',
            ]}>
              <div class="absolute -right-8 -top-8 h-24 w-24 rotate-12 rounded-[2rem] border-[16px] border-white/18 transition duration-500 group-hover:rotate-45"></div>
              <div class="relative flex items-center justify-between gap-4">
                <span class:list={['grid h-10 w-10 place-items-center rounded-full text-xs font-black', index === 1 ? 'bg-[#7eb99a] text-[#0f2233]' : 'bg-white/55 text-[#0f2233]']}>{service.number}</span>
                <span class:list={['text-[10px] font-extrabold uppercase tracking-[0.14em]', index === 1 ? 'text-[#7eb99a]' : 'text-[#0f2233]/72']}>{service.label}</span>
              </div>
              <h3 class="relative mt-3 text-2xl font-extrabold leading-tight">{service.title}</h3>
              <p class:list={['relative mt-3 text-sm leading-6', index === 1 ? 'text-white/76' : 'text-[#0f2233]/72']}>{service.text}</p>
              <span class:list={['relative mt-auto flex items-center gap-2 pt-6 text-sm font-extrabold', index === 1 ? 'text-[#7eb99a]' : 'text-[#0f2233]']}>
                {service.action}
                <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current transition group-hover:translate-x-1" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="fonduri" data-nav-section="fonduri" class="ambient-section relative overflow-hidden border-y border-[#0f2233]/10 py-24 sm:py-32">
      <div class="absolute -right-28 top-16 h-72 w-72 rounded-full border-[50px] border-[#7eb99a]/18"></div>
      <div class="mx-auto max-w-[1240px] px-5 sm:px-8">
        <div class="relative grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:gap-20">
          <div data-reveal>
            <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-[#0f2233]">Oportunități de finanțare</p>
            <h2 class="display-font mt-5 text-5xl leading-[0.98] text-[#0f2233] sm:text-7xl">Programe explicate <span class="italic text-[#0f2233]">clar.</span></h2>
          </div>
          <div data-reveal data-reveal-delay="1" class="flex items-end">
            <p class="max-w-2xl text-lg leading-8 text-[#0f2233]/72">Vezi rapid stadiul, valoarea finanțării și domeniul fiecărui program. Fiecare card deschide o sinteză completă, într-o pagină separată.</p>
          </div>
        </div>

        <div id="lista-programe" data-funding-list class="relative mt-12 scroll-mt-28">
          <div data-reveal class="flex flex-col gap-4 rounded-[1.5rem] border border-[#0f2233]/10 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between sm:p-5">
            <div>
              <span class="text-[10px] font-extrabold uppercase tracking-[0.16em] text-[#0f2233]">Filtrează după stadiu</span>
              <strong class="mt-1 block text-sm text-[#0f2233]"><span data-program-count aria-live="polite">{fundingPrograms.length}</span> programe afișate</strong>
            </div>
            <div class="flex gap-2 overflow-x-auto pb-1 sm:justify-end">
              {fundingStatuses.map((status, index) => (
                <button
                  data-program-filter={status}
                  type="button"
                  aria-pressed={index === 0 ? 'true' : 'false'}
                  class="shrink-0 rounded-full border border-[#0f2233]/12 px-4 py-2.5 text-xs font-extrabold text-[#0f2233]/72 transition hover:border-[#0f2233]/30 hover:text-[#0f2233] aria-pressed:border-[#0f2233] aria-pressed:bg-[#0f2233] aria-pressed:text-white"
                >
                  {status}
                </button>
              ))}
            </div>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {fundingPrograms.map((program, index) => (
              <article data-program-card data-status={program.status} data-reveal data-reveal-delay={String(index % 3)} class="soft-shadow group/card relative aspect-square overflow-hidden rounded-[1.75rem] border border-[#0f2233]/10 bg-[#0f2233] transition duration-500 hover:-translate-y-2 hover:shadow-[0_30px_70px_rgba(15,34,51,0.22)]">
                <img src={`${base}/${program.image}`} alt={program.imageAlt} class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover/card:scale-[1.055]" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-b from-[#0f2233]/28 via-[#0f2233]/4 to-[#0f2233]/94"></div>
                <div class="relative flex h-full flex-col p-5 sm:p-6">
                  <div class="flex items-start justify-between gap-3">
                    <span class="rounded-full border border-white/18 bg-[#0f2233]/78 px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.1em] text-white shadow-lg backdrop-blur-md">{program.funding}</span>
                    <span class:list={['rounded-full border px-3 py-1.5 text-[10px] font-extrabold uppercase tracking-[0.1em] shadow-lg', fundingStatusStyles[program.status]]}>{program.status}</span>
                  </div>
