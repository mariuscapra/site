---
import Layout from '../layouts/Layout.astro';
import { fundingPrograms, fundingStatusStyles } from '../data/fundingPrograms';

const fundingSteps = [
  ['01', 'Diagnostic', 'Clarificăm ideea, profilul solicitantului și investiția vizată.'],
  ['02', 'Eligibilitate', 'Verificăm criteriile, punctajul estimat, riscurile și fezabilitatea.'],
  ['03', 'Strategie', 'Alegem programul și construim logica proiectului, bugetul și calendarul.'],
  ['04', 'Scriere & depunere', 'Pregătim documentația, cererea și răspunsurile la clarificări.'],
  ['05', 'Contractare', 'Te însoțesc în relația cu finanțatorul și în pregătirea implementării.'],
  ['06', 'Implementare', 'Achiziții, monitorizare, rambursare și suport post-implementare.'],
];

const credentials = [
  ['2025', 'Auditor de mediu', 'Calificare recunoscută de Autoritatea Națională pentru Calificări'],
  ['2025', 'Expert achiziții publice', 'Competențe aplicate în proiecte finanțate și proceduri de achiziții'],
  ['2023—prezent', 'Cercetător în economie', 'Academia de Studii Economice din București, proiecte de sustenabilitate'],
  ['2024—prezent', 'Coordonator fonduri europene', 'Management integral, de la oportunitate până la post-implementare'],
];

interface Partner {
  name: string;
  logo: string;
  role: string;
  description: string;
  services: string[];
  url?: string;
}

// Logo-urile vor fi adăugate aici pe măsură ce sunt primite.
const partners: Partner[] = [
  {
    name: 'Nexum Energy',
    logo: 'images/partners/nexum-energy.jpg',
    role: 'Partener tehnic — energie verde',
    description: 'Specialist în soluții fotovoltaice, Nexum Energy asigură componenta tehnică a proiectelor: de la consultanță și configurarea soluției până la furnizarea echipamentelor și montajul complet al sistemelor.',
    services: ['Soluții fotovoltaice', 'Furnizare echipamente', 'Montaj specializat'],
  },
  {
    name: 'ImportMAG',
    logo: 'images/partners/importmag.jpg',
    role: 'Partener tehnic — echipamente și utilaje',
    description: 'ImportMAG susține implementarea investițiilor prin consultanță tehnică și industrială, identificarea soluțiilor potrivite și furnizarea de echipamente și utilaje tehnologice adaptate cerințelor fiecărui proiect.',
    services: ['Consultanță tehnică', 'Soluții industriale', 'Furnizare echipamente și utilaje'],
  },
  {
    name: 'ADN MEDIA',
    logo: 'images/partners/adn-media.png',
    role: 'Partener de implementare — informare și publicitate',
    description: 'ADN MEDIA asigură serviciile de promovare și comunicare necesare proiectelor finanțate, contribuind la creșterea vizibilității investițiilor și la îndeplinirea cerințelor de informare și publicitate din etapa de implementare.',
    services: ['Promovarea proiectelor', 'Vizibilitate și comunicare', 'Informare și publicitate'],
  },
  {
    name: 'FinAudit ESG',
    logo: 'images/partners/finaudit-esg.png',
    role: 'Partener specializat — audit și ESG',
    description: 'FinAudit ESG oferă servicii specializate de audit financiar pentru proiecte, verificarea cheltuielilor și auditarea implementării, completate de evaluări ESG relevante pentru investiții responsabile și sustenabile.',
    services: ['Audit financiar proiecte', 'Auditarea proiectelor', 'Audit ESG'],
    url: 'https://finauditesg.ro/',
  },
];

const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <header class="fixed inset-x-0 top-0 z-50 border-b border-[#17352b]/10 bg-[#fbfaf5]/92 backdrop-blur-xl">
    <div class="mx-auto flex h-20 max-w-[1240px] items-center justify-between px-5 sm:px-8">
      <a href="#top" class="flex items-center gap-3" aria-label="Marius Capră - Acasă">
        <img src={`${base}/logo.svg`} alt="" class="h-11 w-11" width="44" height="44" />
        <span class="leading-none">
          <strong class="block text-[15px] font-extrabold tracking-[0.18em] text-[#073d2c]">CAPRĂ</strong>
          <span class="mt-1 block text-[10px] font-semibold uppercase tracking-[0.16em] text-[#0b6b49]">Fonduri & Mediu</span>
        </span>
      </a>

      <nav class="hidden items-center gap-6 lg:flex" aria-label="Navigare principală">
        <a data-funding-link class="text-sm font-semibold text-[#17352b]/75 transition hover:text-[#0b6b49]" href="#lista-programe">Programe</a>
        <a class="text-sm font-semibold text-[#17352b]/75 transition hover:text-[#0b6b49]" href={`${base}/audit-de-mediu/`}>Audit de mediu</a>
        <a class="text-sm font-semibold text-[#17352b]/75 transition hover:text-[#0b6b49]" href="#despre">Despre</a>
        <a class="text-sm font-semibold text-[#17352b]/75 transition hover:text-[#0b6b49]" href="#parteneri">Parteneri</a>
        <a class="text-sm font-semibold text-[#17352b]/75 transition hover:text-[#0b6b49]" href={`${base}/intrebari-frecvente/`}>Întrebări</a>
      </nav>

      <div class="hidden lg:block">
        <a href="#contact" class="inline-flex items-center gap-2 rounded-full bg-[#0b6b49] px-5 py-3 text-sm font-bold text-white transition hover:-translate-y-0.5 hover:bg-[#073d2c]">
          Hai să discutăm
          <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
        </a>
      </div>

      <button id="menu-button" class="grid h-11 w-11 place-items-center rounded-full border border-[#17352b]/15 text-[#073d2c] lg:hidden" aria-expanded="false" aria-controls="mobile-menu" aria-label="Deschide meniul">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden border-t border-[#17352b]/10 bg-[#fbfaf5] px-5 py-5 lg:hidden">
      <nav class="mx-auto grid max-w-[1240px] gap-1" aria-label="Navigare mobilă">
        <a data-funding-link class="rounded-xl px-4 py-3 font-semibold hover:bg-[#dff1df]" href="#lista-programe">Programe de finanțare</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#dff1df]" href={`${base}/audit-de-mediu/`}>Audit de mediu</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#dff1df]" href="#despre">Despre mine</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#dff1df]" href="#parteneri">Parteneri</a>
        <a class="rounded-xl px-4 py-3 font-semibold hover:bg-[#dff1df]" href={`${base}/intrebari-frecvente/`}>Întrebări frecvente</a>
        <a class="mt-2 rounded-xl bg-[#0b6b49] px-4 py-3 text-center font-bold text-white" href="#contact">Hai să discutăm</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="paper-grid relative overflow-hidden pb-16 pt-32 sm:pb-24 sm:pt-40">
      <div class="absolute -left-24 top-20 h-72 w-72 rounded-full bg-[#dff1df] blur-3xl"></div>
      <div class="absolute right-0 top-0 h-40 w-40 rounded-bl-full bg-[#a7d46f]/40"></div>
      <div class="relative mx-auto grid max-w-[1240px] items-center gap-14 px-5 sm:px-8 lg:grid-cols-[1.08fr_0.92fr] lg:gap-20">
        <div>
          <div data-reveal class="mb-7 inline-flex items-center gap-3 rounded-full border border-[#0b6b49]/20 bg-white/80 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.17em] text-[#0b6b49] shadow-sm">
            <span class="h-2 w-2 rounded-full bg-[#a7d46f] ring-4 ring-[#a7d46f]/25"></span>
            Consultanță cu perspectivă completă
          </div>
          <h1 data-reveal data-reveal-delay="1" class="display-font max-w-[760px] text-[clamp(3.1rem,7vw,6.6rem)] leading-[0.92] text-[#073d2c]">
            Proiecte <span class="italic text-[#0b6b49]">finanțabile.</span><br />Impact sustenabil.
          </h1>
          <p data-reveal data-reveal-delay="2" class="mt-8 max-w-2xl text-lg leading-8 text-[#17352b]/72 sm:text-xl">
            Sunt <strong class="font-bold text-[#17352b]">Marius Capră</strong>. Transform ideile de investiții în proiecte bine argumentate și ajut organizațiile să rămână conforme — de la prima analiză până la implementare.
          </p>
          <div data-reveal data-reveal-delay="3" class="mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="#contact" class="inline-flex items-center justify-center gap-2 rounded-full bg-[#0b6b49] px-7 py-4 font-extrabold text-white shadow-lg shadow-[#0b6b49]/20 transition hover:-translate-y-1 hover:bg-[#073d2c]">
              Evaluează ideea ta
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
            </a>
            <a href="#fonduri" class="inline-flex items-center justify-center rounded-full border border-[#17352b]/20 bg-white/70 px-7 py-4 font-bold text-[#17352b] transition hover:border-[#0b6b49] hover:bg-white">Explorează serviciile</a>
          </div>
          <div data-reveal class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm font-semibold text-[#17352b]/65">
            <span class="flex items-center gap-2"><span class="text-[#0b6b49]">●</span> Programe de finanțare</span>
            <span class="flex items-center gap-2"><span class="text-[#0b6b49]">●</span> Consultanță & implementare</span>
            <span class="flex items-center gap-2"><span class="text-[#0b6b49]">●</span> Audit de mediu</span>
          </div>
        </div>

        <div data-reveal data-reveal-delay="2" class="mx-auto w-full max-w-[520px] lg:mx-0 lg:ml-auto">
          <div class="relative">
            <div class="grain absolute -inset-5 rotate-3 rounded-[2.5rem] bg-[#0b6b49]"></div>
            <div class="soft-shadow relative overflow-hidden rounded-[2rem] border-[7px] border-white bg-[#dff1df]">
              <img src={`${base}/images/marius-capra.jpg`} alt="Marius Capră, consultant în fonduri nerambursabile și auditor de mediu" class="aspect-[4/5] w-full object-cover object-[50%_35%]" width="1500" height="1500" fetchpriority="high" />
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-[#073d2c]/95 via-[#073d2c]/70 to-transparent px-7 pb-7 pt-28 text-white sm:px-9 sm:pb-9">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#cfe8a8]">Strategie • Conformitate • Implementare</p>
                <p class="mt-2 max-w-sm text-lg font-bold leading-snug">Un singur partener pentru întregul parcurs al proiectului.</p>
              </div>
            </div>
            <div class="absolute -bottom-6 -left-3 rounded-2xl border border-[#17352b]/10 bg-[#fbfaf5] p-4 shadow-xl sm:-left-10 sm:p-5">
              <div class="flex items-center gap-3">
                <span class="grid h-11 w-11 place-items-center rounded-full bg-[#a7d46f] text-[#073d2c]">
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8"><path d="m5 13 4 4L19 7" /></svg>
                </span>
                <span><strong class="block text-sm text-[#073d2c]">Abordare integrată</strong><span class="text-xs text-[#17352b]/60">de la idee la rezultate</span></span>
              </div>
            </div>
          </div>
          <a href="https://www.linkedin.com/in/marius-capră-83381919b?utm_source=share_via&amp;utm_content=profile&amp;utm_medium=member_ios" target="_blank" rel="noreferrer" class="group mt-12 flex w-full items-center gap-4 rounded-2xl bg-[#0a66c2] px-5 py-4 text-white shadow-[0_16px_35px_rgba(10,102,194,0.25)] transition duration-300 hover:-translate-y-1 hover:bg-[#084f99] hover:shadow-[0_20px_42px_rgba(10,102,194,0.34)]" aria-label="Vezi profilul LinkedIn al lui Marius Capră">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-white/14">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 fill-current">
                <path d="M6.5 8.3H3V21h3.5V8.3ZM4.75 3A2.05 2.05 0 1 0 4.8 7.1 2.05 2.05 0 0 0 4.75 3ZM21 13.7c0-3.82-2.04-5.6-4.76-5.6-2.2 0-3.18 1.2-3.73 2.05V8.3H9V21h3.51v-6.3c0-1.66.32-3.27 2.38-3.27 2.03 0 2.06 1.9 2.06 3.38V21H21v-7.3Z" />
              </svg>
            </span>
            <span class="min-w-0 flex-1">
              <span class="block text-[10px] font-extrabold uppercase tracking-[0.18em] text-white/70">Conectează-te cu mine</span>
              <strong class="mt-1 block text-sm sm:text-base">Vezi profilul meu pe LinkedIn</strong>
            </span>
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-white/12 transition group-hover:translate-x-1 group-hover:bg-white/20">
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <section class="border-y border-[#17352b]/10 bg-white">
      <div class="mx-auto grid max-w-[1240px] grid-cols-2 px-5 sm:px-8 lg:grid-cols-4">
        <div class="border-b border-r border-[#17352b]/10 py-7 pr-5 lg:border-b-0">
          <strong class="block text-lg font-extrabold text-[#073d2c]">Experiență din 2019</strong><span class="mt-1 block text-sm text-[#17352b]/60">în proiecte finanțate</span>
        </div>
        <div class="border-b border-[#17352b]/10 py-7 pl-5 lg:border-b-0 lg:border-r lg:px-7">
          <strong class="block text-lg font-extrabold text-[#073d2c]">PNRR • POR • PNS</strong><span class="mt-1 block text-sm text-[#17352b]/60">portofoliu divers</span>
        </div>
        <div class="border-r border-[#17352b]/10 py-7 pr-5 lg:px-7">
          <strong class="block text-lg font-extrabold text-[#073d2c]">Expert achiziții</strong><span class="mt-1 block text-sm text-[#17352b]/60">calificare ANC</span>
        </div>
        <div class="py-7 pl-5 lg:pl-7">
          <strong class="block text-lg font-extrabold text-[#073d2c]">Auditor de mediu</strong><span class="mt-1 block text-sm text-[#17352b]/60">calificare ANC</span>
        </div>
      </div>
    </section>

    <section id="fonduri" class="py-24 sm:py-32">
      <div class="mx-auto max-w-[1240px] px-5 sm:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:gap-20">
          <div data-reveal>
            <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[#0b6b49]">01 — Oportunități de finanțare</p>
            <h2 class="display-font mt-5 text-5xl leading-[1.02] text-[#073d2c] sm:text-6xl">Programe de finanțare</h2>
          </div>
          <div data-reveal data-reveal-delay="1" class="flex items-end">
            <p class="max-w-2xl text-lg leading-8 text-[#17352b]/68">Aici vei găsi programele relevante pentru investiții, prezentate clar și actualizate în funcție de stadiul fiecăruia. Pentru fiecare oportunitate vei putea vedea rapid cui se adresează, termenul și statusul apelului.</p>
          </div>
        </div>

        <details id="lista-programe" data-funding-list class="group mt-14" open>
          <summary data-reveal class="soft-shadow flex cursor-pointer list-none items-center justify-between gap-5 rounded-[1.5rem] border border-[#17352b]/10 bg-white px-6 py-5 transition hover:border-[#0b6b49]/30 sm:px-8 [&::-webkit-details-marker]:hidden">
            <span>
              <span class="block text-[10px] font-extrabold uppercase tracking-[0.18em] text-[#0b6b49]">Lista programelor</span>
              <strong class="mt-1 block text-lg text-[#073d2c]">{fundingPrograms.length} {fundingPrograms.length === 1 ? 'program disponibil' : 'programe disponibile'}</strong>
            </span>
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[#dff1df] text-[#0b6b49] transition duration-300 group-open:rotate-180">
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8"><path d="m5 7.5 5 5 5-5" /></svg>
            </span>
          </summary>

          <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {fundingPrograms.map((program, index) => (
              <article data-reveal data-reveal-delay={String(index % 3)} class="soft-shadow group/card relative aspect-square overflow-hidden rounded-[1.75rem] border border-[#17352b]/10 bg-[#073d2c] transition duration-300 hover:-translate-y-1 hover:shadow-[0_28px_70px_rgba(7,61,44,0.2)]">
                <img src={`${base}/${program.image}`} alt={program.imageAlt} class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover/card:scale-[1.03]" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-b from-[#021b13]/15 via-transparent to-[#021b13]/72"></div>
                <div class="relative flex h-full flex-col items-end p-5 sm:p-6">
                  <span class:list={['rounded-full border px-3 py-1.5 text-[9px] font-extrabold uppercase tracking-[0.1em] shadow-lg', fundingStatusStyles[program.status]]}>
                    {program.status}
                  </span>
                  <div class="mt-auto w-full text-white drop-shadow-lg">
                    <p class="text-[9px] font-extrabold uppercase tracking-[0.15em] text-[#cfe8a8]">{program.category}</p>
                    <h3 class="display-font mt-2 text-4xl leading-none">{program.title}</h3>
                  </div>
                  <a href={`${base}/programe/${program.id}/`} target="_blank" rel="noreferrer" class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#a7d46f] px-5 py-3.5 text-sm font-extrabold text-[#073d2c] shadow-xl transition hover:bg-[#cfe8a8]" aria-label={`Deschide sinteza programului ${program.title} într-o filă nouă`}>
                    Vezi sinteza programului
                    <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </details>

        <div class="mt-24">
          <div data-reveal class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
            <div><p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[#0b6b49]">Fluxul colaborării</p><h3 class="display-font mt-3 text-4xl text-[#073d2c] sm:text-5xl">De la idee la implementare</h3></div>
            <p class="max-w-md text-sm leading-6 text-[#17352b]/60">Fiecare etapă are un rezultat clar și o decizie de continuare fundamentată.</p>
          </div>
          <div class="mt-10 grid overflow-hidden rounded-[2rem] border border-[#17352b]/10 bg-white sm:grid-cols-2 lg:grid-cols-3">
            {fundingSteps.map(([number, title, text], index) => (
              <article data-reveal data-reveal-delay={String(index % 3)} class:list={['min-h-56 p-7 sm:p-8', index < 3 && 'lg:border-b lg:border-[#17352b]/10', index % 3 !== 2 && 'lg:border-r lg:border-[#17352b]/10', index % 2 === 0 && 'max-sm:border-b max-sm:border-[#17352b]/10']}>
                <span class="text-sm font-black tracking-[0.15em] text-[#0b6b49]">{number}</span>
                <h4 class="mt-8 text-xl font-extrabold text-[#073d2c]">{title}</h4>
                <p class="mt-3 text-sm leading-6 text-[#17352b]/63">{text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="despre" class="paper-grid py-24 sm:py-32">
      <div class="mx-auto max-w-[1240px] px-5 sm:px-8">
        <div class="grid gap-14 lg:grid-cols-[0.8fr_1.2fr] lg:gap-24">
          <div data-reveal>
            <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[#0b6b49]">Expertiză la intersecția domeniilor</p>
            <h2 class="display-font mt-5 text-5xl leading-[1.02] text-[#073d2c] sm:text-6xl">Înțeleg și finanțarea, și impactul.</h2>
            <p class="mt-7 text-lg leading-8 text-[#17352b]/68">Pregătirea în economie agroalimentară, dezvoltare durabilă și mediu îmi permite să privesc un proiect dincolo de formular: economic, operațional și responsabil.</p>
            <blockquote class="mt-9 border-l-4 border-[#a7d46f] pl-6 text-xl font-bold leading-8 text-[#073d2c]">„Un proiect bun trebuie să fie eligibil pe hârtie și viabil în realitate.”</blockquote>
          </div>

          <div class="grid gap-4">
            {credentials.map(([year, title, text], index) => (
              <article data-reveal data-reveal-delay={String(index % 2)} class="grid gap-3 rounded-2xl border border-[#17352b]/10 bg-white p-6 transition hover:-translate-y-1 hover:border-[#0b6b49]/35 hover:shadow-lg sm:grid-cols-[130px_1fr] sm:items-center">
                <span class="text-xs font-black uppercase tracking-[0.14em] text-[#0b6b49]">{year}</span>
                <div><h3 class="font-extrabold text-[#073d2c]">{title}</h3><p class="mt-1 text-sm leading-6 text-[#17352b]/60">{text}</p></div>
              </article>
            ))}
          </div>
        </div>

        <div data-reveal class="mt-20 overflow-hidden rounded-[2rem] border border-[#17352b]/10 bg-[#f7f4e9]">
          <div class="grid lg:grid-cols-[0.72fr_1.28fr]">
            <div class="bg-[#dff1df] p-7 sm:p-10">
              <p class="text-xs font-extrabold uppercase tracking-[0.2em] text-[#0b6b49]">Plus de perspectivă</p>
              <h3 class="display-font mt-4 text-4xl text-[#073d2c]">Cercetare care susține practica.</h3>
            </div>
            <div class="grid gap-5 p-7 text-sm leading-6 text-[#17352b]/68 sm:grid-cols-2 sm:p-10">
              <p>Autor și coautor de lucrări despre impactul fondurilor nerambursabile asupra antreprenoriatului, economia circulară și dezvoltarea durabilă.</p>
