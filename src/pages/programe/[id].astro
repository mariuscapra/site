---
import Layout from '../../layouts/Layout.astro';
import ManufacturingEligibility from '../../components/ManufacturingEligibility.astro';
import DR12ScoringCalculator from '../../components/DR12ScoringCalculator.astro';
import DigitalizationBIScoringCalculator from '../../components/DigitalizationBIScoringCalculator.astro';
import StartupNationScoringCalculator from '../../components/StartupNationScoringCalculator.astro';
import { fundingPrograms, fundingStatusStyles, type FundingProgram } from '../../data/fundingPrograms';

export function getStaticPaths() {
  return fundingPrograms.map((program) => ({
    params: { id: program.id },
    props: { program },
  }));
}

interface Props {
  program: FundingProgram;
}

const { program } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${program.title} | Sinteza programului`} description={`${program.description} Află condițiile principale, finanțarea, cheltuielile eligibile și obligațiile programului.`}>
  <header class="sticky top-0 z-50 border-b border-[#17352b]/10 bg-[#fbfaf5]/94 backdrop-blur-xl">
    <div class="mx-auto flex h-20 max-w-[1180px] items-center justify-between gap-5 px-5 sm:px-8">
      <a href={`${base}/`} class="flex items-center gap-3" aria-label="Înapoi la pagina principală">
        <img src={`${base}/logo.svg`} alt="" class="h-11 w-11" width="44" height="44" />
        <span class="leading-none">
          <strong class="block text-[15px] font-extrabold tracking-[0.18em] text-[#073d2c]">CAPRĂ</strong>
          <span class="mt-1 block text-[10px] font-semibold uppercase tracking-[0.16em] text-[#0b6b49]">Fonduri & Mediu</span>
        </span>
      </a>
      <a href={`${base}/#lista-programe`} class="inline-flex items-center gap-2 rounded-full border border-[#17352b]/15 bg-white px-4 py-2.5 text-xs font-extrabold text-[#073d2c] transition hover:border-[#0b6b49]/40 hover:text-[#0b6b49]">
        <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M16 10H4m5-5-5 5 5 5" /></svg>
        <span class="hidden sm:inline">Toate programele</span>
        <span class="sm:hidden">Înapoi</span>
      </a>
    </div>
  </header>

  <main>
    <section class="grain relative overflow-hidden bg-[#073d2c] py-20 text-white sm:py-24">
      <div class="absolute -right-28 -top-28 h-96 w-96 rounded-full border-[72px] border-[#a7d46f]/10"></div>
      <div class="absolute -bottom-48 -left-32 h-96 w-96 rounded-full bg-[#0b6b49]/55"></div>
      <div class="relative mx-auto max-w-[1180px] px-5 sm:px-8">
        <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div class="max-w-4xl">
            <div class="flex flex-wrap items-center gap-3">
              <span class:list={['inline-flex rounded-full border px-3 py-1.5 text-[10px] font-extrabold uppercase tracking-[0.12em]', fundingStatusStyles[program.status]]}>{program.status}</span>
              <span class="text-[10px] font-extrabold uppercase tracking-[0.17em] text-[#cfe8a8]">{program.category}</span>
            </div>
            <h1 class="display-font mt-7 text-[clamp(3.5rem,7vw,6.5rem)] leading-[0.9]">{program.title}</h1>
            <p class="mt-7 max-w-3xl text-lg leading-8 text-white/72 sm:text-xl">{program.description}</p>
            <p class="mt-5 max-w-3xl text-xs leading-6 text-white/45">{program.officialName}</p>
          </div>
          <figure class="soft-shadow mx-auto w-full max-w-[460px] overflow-hidden rounded-[2rem] border-[7px] border-white/12 bg-white/8 lg:ml-auto">
            <img src={`${base}/${program.image}`} alt={program.imageAlt} class="aspect-square w-full object-cover" width="1024" height="1024" fetchpriority="high" />
          </figure>
        </div>
      </div>
    </section>

    <section class="relative -mt-8 pb-20 sm:-mt-10 sm:pb-28">
      <div class="mx-auto max-w-[1180px] px-5 sm:px-8">
        <div class="soft-shadow grid overflow-hidden rounded-[1.75rem] border border-[#17352b]/10 bg-white sm:grid-cols-2 lg:grid-cols-4">
          {program.keyFacts.map(([label, value], index) => (
            <div class:list={['p-6 sm:p-7', index < program.keyFacts.length - 1 && 'border-b border-[#17352b]/10 sm:border-b-0 sm:border-r']}>
              <span class="block text-[10px] font-extrabold uppercase tracking-[0.15em] text-[#17352b]/45">{label}</span>
              <strong class="mt-3 block text-lg text-[#073d2c]">{value}</strong>
            </div>
          ))}
        </div>

        <div class="mt-14 grid gap-6 lg:grid-cols-2">
          <section class="rounded-[1.75rem] border border-[#17352b]/10 bg-white p-7 sm:p-9">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-[#dff1df] text-[#0b6b49]">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="1.7"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" /></svg>
            </span>
            <h2 class="display-font mt-6 text-4xl text-[#073d2c]">Cine poate aplica</h2>
            <ul class="mt-6 grid gap-4 text-sm leading-7 text-[#17352b]/70">
              {program.eligibility.map((item) => <li class="flex gap-3"><span class="mt-1 text-[#0b6b49]">●</span><span>{item}</span></li>)}
            </ul>
          </section>

          <section class="rounded-[1.75rem] bg-[#dff1df] p-7 sm:p-9">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-[#0b6b49] text-white">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="1.7"><path d="M9 11 12 14 22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
            </span>
            <h2 class="display-font mt-6 text-4xl text-[#073d2c]">Cum funcționează</h2>
            <ol class="mt-6 grid gap-4 text-sm leading-7 text-[#17352b]/72">
              {program.process.map((item, index) => (
                <li class="flex gap-3">
                  <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-white text-[10px] font-black text-[#0b6b49]">{index + 1}</span>
                  <span>{item}</span>
                </li>
              ))}
            </ol>
          </section>

          <section class="rounded-[1.75rem] border border-[#17352b]/10 bg-white p-7 sm:p-9">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-[#dff1df] text-[#0b6b49]">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="1.7"><path d="M4 4h16v16H4zM8 9h8M8 13h8M8 17h5" /></svg>
            </span>
            <h2 class="display-font mt-6 text-4xl text-[#073d2c]">Cheltuieli eligibile</h2>
            <ul class="mt-6 grid gap-4 text-sm leading-7 text-[#17352b]/70">
              {program.eligibleCosts.map((item) => <li class="flex gap-3"><span class="font-bold text-[#0b6b49]">✓</span><span>{item}</span></li>)}
            </ul>
          </section>

          <section class="rounded-[1.75rem] bg-[#073d2c] p-7 text-white sm:p-9">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-[#a7d46f] text-[#073d2c]">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current" stroke-width="1.7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" /><path d="m9 12 2 2 4-4" /></svg>
            </span>
            <h2 class="display-font mt-6 text-4xl text-white">Obligații importante</h2>
            <ul class="mt-6 grid gap-4 text-sm leading-7 text-white/70">
              {program.obligations.map((item) => <li class="flex gap-3"><span class="font-bold text-[#a7d46f]">✓</span><span>{item}</span></li>)}
            </ul>
          </section>
        </div>

        <div class="mt-8 rounded-[1.75rem] border border-[#c98716]/20 bg-[#fff8e8] p-6 sm:p-8">
          <span class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-[#94600c]">Stadiul programului</span>
          <p class="mt-3 text-base font-bold leading-7 text-[#684508]">{program.deadline}. Calendarul și situația fiecărui solicitant trebuie verificate în platforma și comunicările oficiale.</p>
        </div>

        {program.id === 'start-up-nation-2025' && <StartupNationScoringCalculator />}

        {program.id === 'dr-12-consolidare-exploatatii' && (
          <section data-dr12-calculator class="grain relative mt-8 overflow-hidden rounded-[2rem] bg-[#073d2c] text-white shadow-[0_30px_80px_rgba(7,61,44,0.22)]">
            <div class="absolute -right-32 -top-32 h-96 w-96 rounded-full border-[70px] border-[#a7d46f]/10"></div>
            <div class="relative border-b border-white/10 p-7 sm:p-10">
              <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
                <div class="max-w-3xl">
                  <span class="inline-flex items-center gap-2 rounded-full bg-[#a7d46f] px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.15em] text-[#073d2c]">
                    <span class="h-1.5 w-1.5 rounded-full bg-[#073d2c]"></span>
                    Instrument interactiv
                  </span>
                  <h2 class="display-font mt-5 text-5xl leading-none sm:text-6xl">Verificator rapid DR-12</h2>
                  <p class="mt-5 max-w-2xl text-sm leading-7 text-white/68">Completează profilul fermei și grantul solicitat, de maximum 200.000 euro. Valoarea totală eligibilă și contribuția proprie se calculează automat în funcție de intensitatea aplicabilă.</p>
                </div>
                <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-xs text-white/58">
                  <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 shrink-0 fill-none stroke-[#a7d46f]" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" /><path d="M12 8v4m0 4h.01" /></svg>
                  Estimare orientativă pe baza ghidului consultativ
                </div>
              </div>
            </div>

            <div class="relative grid lg:grid-cols-[1.08fr_0.92fr]">
              <div class="border-b border-white/10 p-7 sm:p-10 lg:border-b-0 lg:border-r">
                <fieldset>
                  <legend class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#cfe8a8]">1. Profilul solicitantului</legend>
                  <div class="mt-4 grid gap-3 sm:grid-cols-2">
                    <label class="cursor-pointer">
                      <input class="peer sr-only" type="radio" name="dr12-profile" value="young" checked />
                      <span class="flex h-full min-h-24 flex-col rounded-2xl border border-white/12 bg-white/5 p-4 transition peer-checked:border-[#a7d46f] peer-checked:bg-[#a7d46f]/12">
                        <strong class="text-sm text-white">Tânăr fermier</strong>
                        <span class="mt-1 text-xs leading-5 text-white/55">Până la 40 de ani inclusiv</span>
                        <span class="mt-auto pt-3 text-[10px] font-black uppercase tracking-[0.12em] text-[#a7d46f]">max. 80%</span>
                      </span>
                    </label>
                    <label class="cursor-pointer">
                      <input class="peer sr-only" type="radio" name="dr12-profile" value="sm61" />
                      <span class="flex h-full min-h-24 flex-col rounded-2xl border border-white/12 bg-white/5 p-4 transition peer-checked:border-[#a7d46f] peer-checked:bg-[#a7d46f]/12">
                        <strong class="text-sm text-white">Beneficiar sM 6.1</strong>
                        <span class="mt-1 text-xs leading-5 text-white/55">Planul de afaceri finalizat</span>
                        <span class="mt-auto pt-3 text-[10px] font-black uppercase tracking-[0.12em] text-[#a7d46f]">max. 65%</span>
                      </span>
                    </label>
                    <label class="cursor-pointer">
                      <input class="peer sr-only" type="radio" name="dr12-profile" value="installed45" />
                      <span class="flex h-full min-h-24 flex-col rounded-2xl border border-white/12 bg-white/5 p-4 transition peer-checked:border-[#a7d46f] peer-checked:bg-[#a7d46f]/12">
                        <strong class="text-sm text-white">Fermier instalat</strong>
                        <span class="mt-1 text-xs leading-5 text-white/55">Între 41 și 45 de ani inclusiv</span>
                        <span class="mt-auto pt-3 text-[10px] font-black uppercase tracking-[0.12em] text-[#a7d46f]">max. 65%</span>
                      </span>
                    </label>
                    <label class="cursor-pointer">
                      <input class="peer sr-only" type="radio" name="dr12-profile" value="other" />
                      <span class="flex h-full min-h-24 flex-col rounded-2xl border border-white/12 bg-white/5 p-4 transition peer-checked:border-[#e8a96a] peer-checked:bg-[#e8a96a]/10">
                        <strong class="text-sm text-white">Alt profil</strong>
                        <span class="mt-1 text-xs leading-5 text-white/55">Peste 45 ani, fără sM 6.1</span>
                        <span class="mt-auto pt-3 text-[10px] font-black uppercase tracking-[0.12em] text-[#e8a96a]">de verificat</span>
                      </span>
                    </label>
                  </div>
                </fieldset>

                <div class="mt-8 grid gap-6 sm:grid-cols-2">
                  <label class="block">
                    <span class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#cfe8a8]">2. Dimensiunea fermei</span>
                    <span class="mt-3 flex items-center rounded-2xl border border-white/12 bg-white/7 px-4 focus-within:border-[#a7d46f]">
                      <input data-dr12-so type="number" min="0" step="500" value="12000" class="min-w-0 flex-1 bg-transparent py-4 text-lg font-extrabold text-white outline-none" />
                      <span class="text-xs font-bold text-white/45">euro SO</span>
                    </span>
                    <span class="mt-2 block text-[11px] text-white/42">Prag orientativ: minimum 12.000 SO</span>
                  </label>
                  <label class="block">
                    <span class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#cfe8a8]">3. Grant nerambursabil solicitat</span>
                    <span class="mt-3 flex items-center rounded-2xl border border-white/12 bg-white/7 px-4 focus-within:border-[#a7d46f]">
                      <input data-dr12-budget type="number" min="1000" max="200000" step="5000" value="200000" class="min-w-0 flex-1 bg-transparent py-4 text-lg font-extrabold text-white outline-none" />
                      <span class="text-xs font-bold text-white/45">euro</span>
                    </span>
                    <input data-dr12-budget-range aria-label="Grant nerambursabil solicitat" type="range" min="10000" max="200000" step="5000" value="200000" class="mt-3 w-full accent-[#a7d46f]" />
                    <span class="mt-2 block text-[11px] leading-5 text-white/42">Plafonul este de până la 200.000 euro. Cofinanțarea se determină prin regula de trei simplă.</span>
                  </label>
                </div>

                <fieldset class="mt-8">
                  <legend class="text-xs font-extrabold uppercase tracking-[0.16em] text-[#cfe8a8]">4. Bifează ce este deja pregătit</legend>
                  <div class="mt-4 grid gap-3 sm:grid-cols-3">
                    <label class="flex h-full cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#a7d46f]/45">
                      <input data-dr12-check="legal" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
                      <span><strong class="block text-xs text-white">Formă juridică</strong><span class="mt-1 block text-[11px] leading-4 text-white/45">PFA / II / IF / SRL</span></span>
                    </label>
                    <label class="flex h-full cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#a7d46f]/45">
                      <input data-dr12-check="registry" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
                      <span><strong class="block text-xs text-white">Înregistrări fermă</strong><span class="mt-1 block text-[11px] leading-4 text-white/45">APIA / ANSVSA / ANZ</span></span>
                    </label>
                    <label class="flex h-full cursor-pointer items-start gap-3 rounded-2xl border border-white/12 bg-white/5 p-4 transition hover:border-[#a7d46f]/45">
                      <input data-dr12-check="skills" class="mt-0.5 h-5 w-5 shrink-0 accent-[#a7d46f]" type="checkbox" checked />
                      <span><strong class="block text-xs text-white">Competențe</strong><span class="mt-1 block text-[11px] leading-4 text-white/45">Pregătire profesională</span></span>
                    </label>
                  </div>
                </fieldset>
              </div>

              <aside class="bg-[#062f22]/72 p-7 sm:p-10">
                <div class="flex items-center justify-between gap-5">
                  <div>
                    <span class="text-[10px] font-extrabold uppercase tracking-[0.16em] text-[#a7d46f]">Rezultat preliminar</span>
                    <strong data-dr12-status class="mt-2 block text-2xl text-white">Profil bine conturat</strong>
                  </div>
                  <div data-dr12-progress class="grid h-20 w-20 shrink-0 place-items-center rounded-full p-[7px]" style="background: conic-gradient(#a7d46f 100%, rgba(255,255,255,.12) 0)">
                    <div class="grid h-full w-full place-items-center rounded-full bg-[#062f22] text-sm font-black text-white"><span data-dr12-score>100%</span></div>
                  </div>
                </div>

                <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
                  <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
                    <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">Intensitate</span>
                    <strong data-dr12-intensity class="mt-2 block text-2xl text-[#a7d46f]">80%</strong>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
                    <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">Grant solicitat</span>
                    <strong data-dr12-grant class="mt-2 block text-2xl text-[#a7d46f]">200.000 €</strong>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
                    <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">Valoare totală eligibilă</span>
                    <strong data-dr12-total-budget class="mt-2 block text-2xl text-white">250.000 €</strong>
                  </div>
                  <div class="rounded-2xl border border-white/10 bg-white/6 p-4">
                    <span class="text-[9px] font-black uppercase tracking-[0.12em] text-white/42">Contribuție minimă</span>
                    <strong data-dr12-private class="mt-2 block text-2xl text-white">50.000 €</strong>
                  </div>
                </div>

                <div class="mt-7 rounded-2xl border border-[#a7d46f]/20 bg-[#a7d46f]/8 p-5">
                  <p data-dr12-message class="text-sm font-semibold leading-6 text-[#eaf5db]">Datele introduse indică o posibilă încadrare. Următorul pas este calcularea punctajului și verificarea documentelor.</p>
                </div>

                <div class="mt-7">
                  <div role="tablist" aria-label="Pregătirea proiectului DR-12" class="grid grid-cols-3 gap-1 rounded-xl bg-white/7 p-1">
                    <button data-dr12-tab="eligibility" type="button" role="tab" aria-selected="true" class="rounded-lg px-2 py-2.5 text-[10px] font-black uppercase tracking-[0.08em] text-white/55 transition aria-selected:bg-[#a7d46f] aria-selected:text-[#073d2c]">Eligibilitate</button>
                    <button data-dr12-tab="score" type="button" role="tab" aria-selected="false" class="rounded-lg px-2 py-2.5 text-[10px] font-black uppercase tracking-[0.08em] text-white/55 transition aria-selected:bg-[#a7d46f] aria-selected:text-[#073d2c]">Punctaj</button>
                    <button data-dr12-tab="documents" type="button" role="tab" aria-selected="false" class="rounded-lg px-2 py-2.5 text-[10px] font-black uppercase tracking-[0.08em] text-white/55 transition aria-selected:bg-[#a7d46f] aria-selected:text-[#073d2c]">Documente</button>
                  </div>
                  <div data-dr12-panel="eligibility" role="tabpanel" class="mt-4 text-xs leading-6 text-white/60">Verifică vârsta și instalarea, forma juridică, dimensiunea SO, calitatea de șef al exploatației și înregistrarea completă a fermei.</div>
                  <div data-dr12-panel="score" role="tabpanel" class="mt-4 hidden text-xs leading-6 text-white/60">Prima etapă pornește la 75 de puncte, iar pragul minim este 45. Contează calificarea, asocierea, proprietatea, agricultura de precizie și managementul riscului.</div>
                  <div data-dr12-panel="documents" role="tabpanel" class="mt-4 hidden text-xs leading-6 text-white/60">Pregătește cererea AFIR, studiul de fezabilitate, documentele exploatației, drepturile asupra imobilelor, ofertele, avizele și dovada cofinanțării.</div>
                </div>

                <a href={`${base}/#contact`} class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#a7d46f] px-6 py-4 text-sm font-extrabold text-[#073d2c] transition hover:-translate-y-0.5 hover:bg-[#cfe8a8]">
                  Cere analiza completă DR-12
                  <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
                </a>
              </aside>
            </div>
          </section>
        )}

        {program.id === 'dr-12-consolidare-exploatatii' && <DR12ScoringCalculator />}

        {program.id === 'pr-bi-transformare-digitala-imm' && <DigitalizationBIScoringCalculator />}

        {program.id === 'investitii-deficit-comercial-industrie' && <ManufacturingEligibility />}

        {program.eligibleCaen && program.eligibleCaen.length > 0 && (
          <section class="mt-8 rounded-[1.75rem] border border-[#17352b]/10 bg-white p-7 sm:p-9">
            <div class="max-w-3xl">
              <span class="text-[10px] font-extrabold uppercase tracking-[0.16em] text-[#0b6b49]">Anexa nr. 2</span>
              <h2 class="display-font mt-3 text-4xl text-[#073d2c] sm:text-5xl">Coduri CAEN eligibile</h2>
              <p class="mt-4 text-sm leading-7 text-[#17352b]/62">Activitatea finanțată trebuie să se încadreze în unul dintre codurile prevăzute de schema PRO-INFRA.</p>
            </div>
            <div class="mt-7 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {program.eligibleCaen.map(([code, description]) => (
                <article class="rounded-2xl border border-[#17352b]/10 bg-[#f7f4e9] p-5">
                  <span class="inline-flex rounded-full bg-[#0b6b49] px-3 py-1 text-xs font-black tracking-[0.08em] text-white">CAEN {code}</span>
                  <p class="mt-4 text-sm font-semibold leading-6 text-[#17352b]/74">{description}</p>
                </article>
              ))}
            </div>
          </section>
        )}

        <section class="grain relative mt-8 overflow-hidden rounded-[2rem] bg-[#0b6b49] p-7 text-white sm:p-10">
          <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full border-[44px] border-[#a7d46f]/15"></div>
          <div class="relative flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-2xl">
              <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-[#cfe8a8]">Pregătești o investiție?</p>
              <h2 class="display-font mt-3 text-4xl sm:text-5xl">Verificăm împreună eligibilitatea.</h2>
              <p class="mt-4 text-sm leading-7 text-white/68">Analizăm profilul solicitantului, investiția, codul CAEN și punctajul estimat înainte de a începe documentația.</p>
            </div>
            <a href={`${base}/#contact`} class="inline-flex shrink-0 items-center justify-center gap-2 rounded-full bg-[#a7d46f] px-6 py-4 text-sm font-extrabold text-[#073d2c] transition hover:-translate-y-1 hover:bg-[#cfe8a8]">
              Solicită o evaluare
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4 fill-none stroke-current" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
            </a>
          </div>
        </section>

        {program.sources.length > 0 && (
          <section class="mt-12 border-t border-[#17352b]/10 pt-8">
            <h2 class="text-xs font-extrabold uppercase tracking-[0.17em] text-[#073d2c]">Surse oficiale</h2>
            <div class="mt-4 flex flex-wrap gap-x-6 gap-y-3 text-sm font-bold">
              {program.sources.map((source) => (
                <a href={source.url} target="_blank" rel="noreferrer" class="text-[#0b6b49] hover:text-[#073d2c]">{source.label} ↗</a>
              ))}
            </div>
            <p class="mt-5 max-w-4xl text-xs leading-6 text-[#17352b]/48">Această pagină este o sinteză informativă. În cazul unor diferențe sau actualizări, prevederile procedurii și comunicările autorității finanțatoare prevalează.</p>
          </section>
        )}
      </div>
    </section>
  </main>

  <footer class="border-t border-[#17352b]/10 px-5 py-8 sm:px-8">
    <div class="mx-auto flex max-w-[1180px] flex-col gap-4 text-xs text-[#17352b]/55 sm:flex-row sm:items-center sm:justify-between">
      <span>© {new Date().getFullYear()} Marius Capră</span>
      <a href={`${base}/`} class="font-bold text-[#0b6b49] hover:text-[#073d2c]">Înapoi la pagina principală</a>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const calculator = document.querySelector('[data-dr12-calculator]');
      if (!calculator) return;

      const profileInputs = [...calculator.querySelectorAll('input[name="dr12-profile"]')];
      const soInput = calculator.querySelector('[data-dr12-so]');
      const budgetInput = calculator.querySelector('[data-dr12-budget]');
      const budgetRange = calculator.querySelector('[data-dr12-budget-range]');
      const checks = [...calculator.querySelectorAll('[data-dr12-check]')];
      const formatEuro = new Intl.NumberFormat('ro-RO', { maximumFractionDigits: 0 });

      const readChecked = (name) => calculator.querySelector(`[data-dr12-check="${name}"]`)?.checked ?? false;
      const setText = (selector, value) => {
        const element = calculator.querySelector(selector);
        if (element) element.textContent = value;
      };

      const update = () => {
        const profile = profileInputs.find((input) => input.checked)?.value ?? 'other';
        const so = Math.max(0, Number(soInput?.value) || 0);
        const requestedGrant = Math.min(200000, Math.max(0, Number(budgetInput?.value) || 0));
        const profileEligible = profile !== 'other';
        const legal = readChecked('legal');
        const registry = readChecked('registry');
        const skills = readChecked('skills');
        const soEligible = so >= 12000;
        const conditions = [profileEligible, soEligible, legal, registry, skills];
        const readiness = Math.round((conditions.filter(Boolean).length / conditions.length) * 100);
        const intensity = profileEligible ? (profile === 'young' && skills ? 0.8 : 0.65) : 0;
        const totalEligibleBudget = intensity ? requestedGrant / intensity : 0;
        const privateContribution = Math.max(0, totalEligibleBudget - requestedGrant);

        setText('[data-dr12-score]', `${readiness}%`);
        setText('[data-dr12-intensity]', intensity ? `${Math.round(intensity * 100)}%` : '—');
        setText('[data-dr12-grant]', intensity ? `${formatEuro.format(requestedGrant)} €` : '—');
        setText('[data-dr12-total-budget]', intensity ? `${formatEuro.format(totalEligibleBudget)} €` : '—');
        setText('[data-dr12-private]', intensity ? `${formatEuro.format(privateContribution)} €` : '—');

        const progress = calculator.querySelector('[data-dr12-progress]');
        if (progress) progress.style.background = `conic-gradient(${readiness === 100 ? '#a7d46f' : '#e8a96a'} ${readiness}%, rgba(255,255,255,.12) 0)`;

        let status = 'Profil bine conturat';
        let message = 'Datele introduse indică o posibilă încadrare. Următorul pas este calcularea punctajului și verificarea documentelor.';
        if (!profileEligible) {
          status = 'Profilul necesită clarificare';
          message = 'Categoria selectată nu se regăsește direct între beneficiarii prevăzuți de ghidul consultativ. Verifică istoricul instalării și o eventuală finanțare sM 6.1.';
        } else if (!soEligible) {
          status = 'Dimensiune SO sub prag';
          message = 'Exploatația introdusă este sub pragul orientativ de 12.000 SO. Dimensiunea economică trebuie recalculată pe baza culturilor și efectivelor declarate.';
        } else if (!legal || !registry || !skills) {
          status = 'Mai sunt pași de pregătit';
          message = 'Profilul de bază poate fi potrivit, dar elementele nebifate trebuie clarificate înainte de depunere. Verificarea completă poate schimba rezultatul.';
        }
        setText('[data-dr12-status]', status);
        setText('[data-dr12-message]', message);
      };

      budgetRange?.addEventListener('input', () => {
        budgetInput.value = budgetRange.value;
        update();
      });
      budgetInput?.addEventListener('input', () => {
        const value = Math.min(200000, Math.max(10000, Number(budgetInput.value) || 10000));
        budgetInput.value = String(value);
        budgetRange.value = String(value);
        update();
      });
      [...profileInputs, soInput, ...checks].filter(Boolean).forEach((input) => input.addEventListener('input', update));

      const tabs = [...calculator.querySelectorAll('[data-dr12-tab]')];
      const panels = [...calculator.querySelectorAll('[data-dr12-panel]')];
      tabs.forEach((tab) => tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-dr12-tab');
        tabs.forEach((item) => item.setAttribute('aria-selected', String(item === tab)));
        panels.forEach((panel) => panel.classList.toggle('hidden', panel.getAttribute('data-dr12-panel') !== target));
      }));

      update();
    })();
  </script>
</Layout>
