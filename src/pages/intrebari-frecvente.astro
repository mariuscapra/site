---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    category: 'Fonduri europene',
    question: 'Ce programe de finanțare pot fi potrivite pentru un IMM în 2026?',
    answer: 'Programul potrivit depinde de regiunea investiției, dimensiunea firmei, codul CAEN, vechime, rezultate financiare și tipul cheltuielilor. Pentru IMM-uri pot exista apeluri regionale pentru investiții productive sau digitalizare, scheme naționale și ajutoare de stat. Lista programelor de pe site este orientativă, iar eligibilitatea se confirmă numai după publicarea ghidului final.',
  },
  {
    category: 'Eligibilitate',
    question: 'Cum verific dacă un SRL este eligibil pentru fonduri europene?',
    answer: 'Verificarea unui SRL începe cu vechimea, categoria IMM, situațiile financiare, profitul solicitat de apel, datoriile, codul CAEN, locația și dreptul asupra imobilului. Apoi se analizează investiția, bugetul, cofinanțarea, ajutoarele de minimis primite și criteriile de punctaj. Condițiile trebuie îndeplinite cumulativ, nu doar parțial.',
  },
  {
    category: 'Eligibilitate',
    question: 'Pot solicita finanțare un PFA, o întreprindere individuală sau o întreprindere familială?',
    answer: 'Da, dar numai în programele care includ expres PFA, II sau IF între beneficiarii eligibili. Unele intervenții agricole, precum DR-12, pot accepta aceste forme juridice, în timp ce multe apeluri pentru IMM-uri solicită societăți comerciale. Forma juridică trebuie verificată în ghidul fiecărui apel.',
  },
  {
    category: 'Eligibilitate',
    question: 'Este obligatoriu ca firma să fi înregistrat profit în ultimul an fiscal?',
    answer: 'Depinde de program. Unele apeluri solicită profit din exploatare mai mare de zero în anul fiscal anterior, capitaluri proprii pozitive sau rentabilitate pozitivă într-un anumit interval. Alte programe acceptă firme nou-înființate. Situațiile financiare trebuie verificate exact după definiția din ghid.',
  },
  {
    category: 'Eligibilitate',
    question: 'Ce drept trebuie să am asupra locației de implementare a proiectului?',
    answer: 'Ghidul poate solicita proprietate, concesiune, superficie, administrare, închiriere sau un alt drept valabil, în funcție de investiție și de existența lucrărilor de construcții. Dreptul trebuie să acopere perioada de implementare și durabilitate, iar imobilul trebuie să permită legal activitatea și investiția propusă.',
  },
  {
    category: 'Eligibilitate',
    question: 'Cum verific dacă un cod CAEN este eligibil și autorizat corect?',
    answer: 'Codul CAEN trebuie verificat în lista apelului, în versiunea CAEN cerută de ghid, apoi corelat cu activitatea finanțată și locația proiectului. Unele programe cer codul înscris la depunere și autorizat până la contractare sau prima plată. Eligibilitatea codului nu înseamnă automat că toate cheltuielile sunt eligibile.',
  },
  {
    category: 'Fonduri europene',
    question: 'Cum se calculează cofinanțarea proprie de 10%–35%?',
    answer: 'Cofinanțarea se calculează ca procent din valoarea eligibilă a proiectului. De exemplu, la o intensitate de 80%, grantul reprezintă 80% din costurile eligibile, iar contribuția privată 20%. Beneficiarul suportă separat cheltuielile neeligibile, TVA-ul neeligibil și necesarul temporar de numerar până la rambursare.',
  },
  {
    category: 'Fonduri europene',
    question: 'Ce trebuie să știe un IMM din București–Ilfov despre finanțarea pentru digitalizare avansată?',
    answer: 'Un IMM din București–Ilfov trebuie să verifice sediul și locația de implementare, vechimea minimă, codul CAEN, dreptul asupra spațiului și contribuția proprie. Investiția trebuie fundamentată prin audit de maturitate digitală și plan de digitalizare, iar soluțiile ERP, CRM, automatizare sau securitate cibernetică trebuie legate de procese reale ale firmei.',
  },
  {
    category: 'Fonduri europene',
    question: 'Cum se calculează punctajul pentru Start-Up Nation 2025?',
    answer: 'Punctajul se calculează conform criteriilor din procedură: aport propriu, ponderea echipamentelor, componenta de dezvoltare durabilă, debutul în afaceri, menținerea locurilor de muncă și domeniul de activitate. Calculatorul de pe pagina programului oferă o prescorare orientativă; autoritatea finanțatoare stabilește scorul final.',
  },
  {
    category: 'Fonduri europene',
    question: 'La DR-12, grantul de până la 200.000 euro este o sumă fixă?',
    answer: 'Nu. 200.000 euro este plafonul maxim al sprijinului nerambursabil, iar grantul efectiv rezultă din valoarea eligibilă și intensitatea aplicabilă, de exemplu 80% sau 65%. Cofinanțarea se calculează proporțional, prin regula de trei simplă, iar beneficiarul suportă integral cheltuielile neeligibile.',
  },
  {
    category: 'Colaborare',
    question: 'Cât costă serviciile de consultanță pentru fonduri europene?',
    answer: 'Costul consultanței se stabilește după o analiză inițială și depinde de program, valoarea și complexitatea investiției, documentația tehnică și serviciile solicitate: eligibilitate, scriere, depunere, achiziții sau implementare. Oferta prezintă clar etapele, livrabilele, termenele și condițiile de plată.',
  },
  {
    category: 'Colaborare',
    question: 'Ce documente sunt necesare pentru o verificare inițială de eligibilitate?',
    answer: 'Pentru început sunt utile CUI-ul firmei, forma juridică, locația investiției, codul CAEN, ultimele situații financiare, o descriere a investiției, bugetul estimat și sursa cofinanțării. Ulterior pot fi necesare documente asupra imobilului, oferte, certificate fiscale, avize și documentații tehnice.',
  },
  {
    category: 'Implementare',
    question: 'Pot comanda echipamente sau începe lucrările înainte de depunerea proiectului?',
    answer: 'Nu înainte de verificarea regulilor privind demararea investiției și efectul stimulativ. O comandă fermă, un contract de execuție, plata unui avans sau începerea lucrărilor poate face proiectul neeligibil. Activitățile pregătitoare permise trebuie delimitate clar de demararea ireversibilă a investiției.',
  },
  {
    category: 'Achiziții',
    question: 'Cum se organizează achiziția de echipamente într-un proiect cu fonduri europene?',
    answer: 'Achiziția pornește de la specificații tehnice neutre și un buget justificat. Se aplică procedura beneficiarului și cerințele programului privind publicitatea, solicitarea ofertelor, conflictele de interese, evaluarea și contractarea. Dosarul achiziției trebuie să permită verificarea completă a deciziei și a prețului.',
  },
  {
    category: 'Achiziții',
    question: 'Ce riscuri apar dacă procedura de achiziție este realizată greșit?',
    answer: 'Specificațiile restrictive, ofertele necomparabile, alegerea insuficient justificată, conflictul de interese sau lipsa documentelor pot genera cheltuieli neeligibile și corecții financiare. Prevenția înseamnă planificare, trasabilitate și verificarea documentației înainte de publicare sau transmitere.',
  },
  {
    category: 'Implementare',
    question: 'Ce presupune implementarea unui proiect după semnarea contractului de finanțare?',
    answer: 'Implementarea include actualizarea calendarului, achiziții, contracte cu furnizorii, plăți, cereri de plată sau rambursare, raportare tehnică și financiară, vizibilitate și monitorizarea indicatorilor. Modificările de buget, soluție tehnică sau calendar trebuie analizate înainte de a fi aplicate.',
  },
  {
    category: 'Implementare',
    question: 'Ce obligații trebuie menținute după finalizarea proiectului?',
    answer: 'Beneficiarul menține, de regulă, investiția, activitatea, locația, activele, locurile de muncă și indicatorii pe perioada de durabilitate. Documentele se arhivează, activele nu se înstrăinează fără aprobare și se respectă cerințele de informare, mediu și evitare a dublei finanțări.',
  },
  {
    category: 'Audit de mediu',
    question: 'Ce este un audit de mediu și când este util unei firme?',
    answer: 'Auditul de mediu este o evaluare structurată a conformării și performanței de mediu. Este util înaintea unei investiții, pentru pregătirea unui control, verificarea autorizațiilor, gestiunea deșeurilor, consumurile de resurse și identificarea riscurilor care pot produce sancțiuni sau întârzieri.',
  },
  {
    category: 'Audit de mediu',
    question: 'Ce documente sunt verificate într-un audit de mediu?',
    answer: 'În funcție de activitate, se verifică actele de reglementare, evidența deșeurilor, contractele cu operatorii autorizați, raportările, monitorizările, consumurile, obligațiile pentru ambalaje și substanțe, instruirile și procedurile interne. Auditul se finalizează cu neconformități, priorități și măsuri recomandate.',
  },
  {
    category: 'Audit de mediu',
    question: 'Pot contracta auditul de mediu separat de consultanța pentru fonduri europene?',
    answer: 'Da. Auditul de mediu poate fi contractat ca serviciu independent pentru activitatea curentă, o investiție nouă, pregătirea unei verificări sau organizarea documentelor și responsabilităților de mediu. Livrabilele și limitele evaluării sunt stabilite înainte de începerea auditului.',
  },
  {
    category: 'Colaborare',
    question: 'Poate un consultant să garanteze aprobarea unui proiect cu fonduri europene?',
    answer: 'Nu. Aprobarea depinde de autoritatea finanțatoare, condițiile apelului, punctaj, buget și concurență. Un consultant poate verifica eligibilitatea, estima realist punctajul, construi documentația și reduce riscurile, dar nu poate promite rezultatul evaluării.',
  },
];

const categories = ['Toate', 'Fonduri europene', 'Eligibilitate', 'Colaborare', 'Achiziții', 'Implementare', 'Audit de mediu'];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentYear = new Date().getFullYear();
const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
});
---

<Layout
  title="Întrebări despre fonduri europene și audit de mediu | Marius Capră"
  description="Răspunsuri specifice despre eligibilitatea IMM, cofinanțare, cod CAEN, Start-Up Nation, DR-12, achiziții, implementare și audit de mediu."
>
  <script is:inline type="application/ld+json" set:html={faqSchema} />

  <header class="sticky top-0 z-50 border-b border-[#0f2233]/10 bg-[#ffffff]/94 backdrop-blur-xl">
    <div class="mx-auto flex h-20 max-w-[1240px] items-center justify-between gap-5 px-5 sm:px-8">
      <a href={`${base}/`} class="flex items-center gap-3" aria-label="Înapoi la pagina principală">
        <img src={`${base}/logo.svg`} alt="" class="h-11 w-11" width="44" height="44" />
        <span class="leading-none">
          <strong class="block text-[15px] font-extrabold tracking-[0.18em] text-[#0f2233]">CAPRĂ</strong>
          <span class="mt-1 block text-[10px] font-semibold uppercase tracking-[0.16em] text-[#0f2233]">Fonduri & Mediu</span>
        </span>
      </a>

      <nav class="hidden items-center gap-6 lg:flex" aria-label="Navigare întrebări frecvente">
        <a href={`${base}/#lista-programe`} class="text-sm font-semibold text-[#0f2233]/70 transition hover:text-[#0f2233]">Programe</a>
        <a href={`${base}/diagnostic-proiect/`} class="text-sm font-semibold text-[#0f2233]/70 transition hover:text-[#0f2233]">Diagnostic</a>
        <a href={`${base}/audit-de-mediu/`} class="text-sm font-semibold text-[#0f2233]/70 transition hover:text-[#0f2233]">Audit de mediu</a>
        <a href={`${base}/#despre`} class="text-sm font-semibold text-[#0f2233]/70 transition hover:text-[#0f2233]">Despre</a>
        <a href={`${base}/studii-de-caz/`} class="text-sm font-semibold text-[#0f2233]/70 transition hover:text-[#0f2233]">Studii de caz</a>
        <a href={`${base}/#parteneri`} class="text-sm font-semibold text-[#0f2233]/70 transition hover:text-[#0f2233]">Parteneri</a>
      </nav>

      <a href={`${base}/#formular-proiect`} class="hidden items-center gap-2 rounded-full bg-[#0f2233] px-4 py-3 text-xs font-extrabold text-white transition hover:-translate-y-0.5 hover:bg-[#0f2233] sm:inline-flex sm:px-5 sm:text-sm">
        Pune o întrebare
        <svg aria-hidden="true" viewBox="0 0 20 20" class="hidden h-4 w-4 fill-none stroke-current sm:block" stroke-width="1.8"><path d="M4 10h12M11 5l5 5-5 5" /></svg>
      </a>
      <button data-faq-menu-button type="button" class="grid h-11 w-11 place-items-center rounded-full border border-[#0f2233]/15 text-[#0f2233] lg:hidden" aria-expanded="false" aria-controls="faq-mobile-menu" aria-label="Deschide meniul">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
      </button>
    </div>
    <div id="faq-mobile-menu" class="hidden border-t border-[#0f2233]/10 bg-white px-5 py-4 shadow-xl lg:hidden">
      <nav class="mx-auto grid max-w-[1240px] gap-1" aria-label="Navigare mobilă întrebări frecvente">
        <a href={`${base}/`} class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]">Pagina principală</a>
        <a href={`${base}/#lista-programe`} class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]">Programe de finanțare</a>
        <a href={`${base}/diagnostic-proiect/`} class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]">Diagnostic proiect</a>
        <a href={`${base}/audit-de-mediu/`} class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]">Audit de mediu</a>
        <a href={`${base}/studii-de-caz/`} class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]">Studii de caz</a>
        <a href={`${base}/#parteneri`} class="rounded-xl px-4 py-3 font-semibold hover:bg-[#f5f7f6]">Parteneri</a>
        <a href={`${base}/#formular-proiect`} class="mt-2 rounded-xl bg-[#0f2233] px-4 py-3 text-center font-extrabold text-white">Descrie proiectul</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="paper-grid relative overflow-hidden pb-16 pt-20 sm:pb-24 sm:pt-28">
      <div class="absolute -left-24 top-8 h-80 w-80 rounded-full bg-[#f5f7f6] blur-3xl"></div>
      <div class="absolute right-0 top-0 h-48 w-48 rounded-bl-full bg-[#7eb99a]/35"></div>
      <div class="relative mx-auto max-w-[1240px] px-5 sm:px-8">
        <div class="grid gap-12 lg:grid-cols-[1fr_0.72fr] lg:items-end lg:gap-24">
          <div>
            <p class="section-kicker">Întrebări frecvente</p>
            <h1 class="display-font mt-5 max-w-4xl text-[clamp(3.1rem,7.5vw,6.7rem)] leading-[0.98] text-[#0f2233] sm:leading-[0.94]">Fonduri europene și audit de mediu, explicate concret.</h1>
          </div>
          <div>
            <p class="text-lg leading-8 text-[#0f2233]/72">Răspunsuri specifice despre eligibilitatea IMM, cofinanțare, cod CAEN, pregătirea proiectului, achiziții și conformarea de mediu. Folosește căutarea sau filtrează după subiect.</p>
            <div class="mt-6 flex items-center gap-3 text-sm font-bold text-[#0f2233]">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-[#f5f7f6]">{faqs.length}</span>
              răspunsuri practice
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-24 sm:pb-32">
      <div class="mx-auto max-w-[1240px] px-5 sm:px-8">
        <div class="soft-shadow sticky top-24 z-30 rounded-[1.5rem] border border-[#0f2233]/10 bg-white/95 p-4 backdrop-blur-xl sm:p-5">
          <div class="grid gap-4 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
            <label class="flex items-center gap-3 rounded-xl border border-[#0f2233]/12 bg-[#f7f8f7] px-4 focus-within:border-[#0f2233]">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 shrink-0 fill-none stroke-[#0f2233]" stroke-width="1.8"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
              <input data-faq-search type="search" aria-label="Caută în întrebările frecvente" class="min-w-0 flex-1 bg-transparent py-3.5 text-sm outline-none" placeholder="Caută: SRL, CAEN, DR-12, cofinanțare..." />
            </label>
            <div class="flex gap-2 overflow-x-auto pb-1 lg:justify-end">
              {categories.map((category, index) => (
                <button
                  data-faq-filter={category}
                  type="button"
                  aria-pressed={index === 0 ? 'true' : 'false'}
                  class="shrink-0 rounded-full border border-[#0f2233]/12 px-4 py-2.5 text-xs font-extrabold text-[#0f2233]/72 transition aria-pressed:border-[#0f2233] aria-pressed:bg-[#0f2233] aria-pressed:text-white"
                >
                  {category}
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-10 grid gap-8 lg:grid-cols-[0.32fr_0.68fr] lg:gap-16">
          <aside>
            <div class="sticky top-52 rounded-[1.75rem] bg-[#0f2233] p-7 text-white sm:p-8">
              <p class="text-[10px] font-extrabold uppercase tracking-[0.18em] text-[#7eb99a]">Rezultate afișate</p>
              <strong data-faq-count class="display-font mt-3 block text-6xl">{faqs.length}</strong>
              <p class="mt-4 text-sm leading-7 text-white/76">Nu ai găsit răspunsul potrivit? Trimite situația ta și o clarificăm într-o discuție inițială.</p>
              <a href={`${base}/#formular-proiect`} class="mt-7 inline-flex w-full items-center justify-center rounded-full bg-[#7eb99a] px-5 py-3.5 text-sm font-extrabold text-[#0f2233] transition hover:bg-white">Descrie proiectul</a>
            </div>
          </aside>

          <div data-faq-list class="border-t border-[#0f2233]/14">
            {faqs.map((faq) => (
              <details data-faq-item data-category={faq.category} data-search={`${faq.question} ${faq.answer}`} class="group border-b border-[#0f2233]/14">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-5 py-6 sm:py-7 [&::-webkit-details-marker]:hidden">
                  <span>
                    <span class="text-[10px] font-black uppercase tracking-[0.16em] text-[#0f2233]">{faq.category}</span>
                    <strong class="mt-2 block text-base leading-7 text-[#0f2233] sm:text-lg">{faq.question}</strong>
                  </span>
                  <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-[#f5f7f6] text-xl font-normal text-[#0f2233] transition group-open:rotate-45">+</span>
                </summary>
                <p class="max-w-3xl pb-8 pr-8 text-sm leading-7 text-[#0f2233]/72 sm:text-base sm:leading-8">{faq.answer}</p>
              </details>
            ))}
            <div data-faq-empty class="hidden rounded-[1.75rem] bg-[#f5f7f6] p-8 text-center">
              <strong class="text-[#0f2233]">Nu am găsit o întrebare care să corespundă căutării.</strong>
              <p class="mt-2 text-sm text-[#0f2233]/70">Încearcă un termen mai scurt sau selectează categoria „Toate”.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-[#0f2233]/10 px-5 py-9 sm:px-8">
    <div class="mx-auto flex max-w-[1240px] flex-col gap-5 text-xs text-[#0f2233]/72 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3"><img src={`${base}/logo.svg`} alt="" class="h-9 w-9" width="36" height="36" /><strong class="tracking-[0.14em] text-[#0f2233]">CAPRĂ · FONDURI & MEDIU</strong></div>
      <span>© {currentYear} Marius Capră. Toate drepturile rezervate.</span>
      <a href={`${base}/`} class="font-bold text-[#0f2233] hover:text-[#0f2233]">Înapoi la pagina principală</a>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const menuButton = document.querySelector('[data-faq-menu-button]');
      const mobileMenu = document.querySelector('#faq-mobile-menu');
      menuButton?.addEventListener('click', () => {
        const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
        menuButton.setAttribute('aria-expanded', String(!isOpen));
        menuButton.setAttribute('aria-label', isOpen ? 'Deschide meniul' : 'Închide meniul');
        mobileMenu?.classList.toggle('hidden', isOpen);
      });
      mobileMenu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuButton?.setAttribute('aria-expanded', 'false');
      }));

      const searchInput = document.querySelector('[data-faq-search]');
      const filters = [...document.querySelectorAll('[data-faq-filter]')];
      const items = [...document.querySelectorAll('[data-faq-item]')];
      const count = document.querySelector('[data-faq-count]');
      const empty = document.querySelector('[data-faq-empty]');
      let activeCategory = 'Toate';

      const normalize = (value) => value
        .toLocaleLowerCase('ro-RO')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');

      const update = () => {
        const query = normalize(searchInput?.value ?? '').trim();
        let visible = 0;

        items.forEach((item) => {
          const categoryMatches = activeCategory === 'Toate' || item.dataset.category === activeCategory;
          const searchMatches = !query || normalize(item.dataset.search ?? '').includes(query);
          const show = categoryMatches && searchMatches;
          item.classList.toggle('hidden', !show);
          if (show) visible += 1;
        });

        if (count) count.textContent = String(visible);
        empty?.classList.toggle('hidden', visible !== 0);
      };

      filters.forEach((button) => {
        button.addEventListener('click', () => {
          activeCategory = button.dataset.faqFilter ?? 'Toate';
          filters.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
          update();
        });
      });

      searchInput?.addEventListener('input', update);
      update();
    })();
  </script>
</Layout>
